<% content_for :title, "Perfil de Usuario — FEC" %>
<% content_for :page_title, "Actualización de la Información del Usuario" %>

<div data-controller="user-profile"
     data-testid="user-profile-page"
     class="p-6 max-w-4xl mx-auto">

  <%# ---------------------------------------------------------------- %>
  <%# TÍTULO %>
  <%# ---------------------------------------------------------------- %>
  <h1 data-testid="page-title"
      class="text-xl font-semibold text-gray-700 mb-6 hidden">
    Actualización de la Información del Usuario
  </h1>

  <%# ---------------------------------------------------------------- %>
  <%# FORMULARIO %>
  <%# ---------------------------------------------------------------- %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
    <form data-user-profile-target="form"
          data-action="submit->user-profile#onSubmit"
          novalidate>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

        <%# Campo: Usuario de SAP %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Usuario de SAP <span class="text-red-500">*</span>
          </label>
          <input type="text"
                 data-user-profile-target="sapUserInput"
                 data-testid="sap-user-input"
                 data-action="input->user-profile#onCredentialChange"
                 placeholder="Usuario de SAP"
                 class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                 required>
          <p data-user-profile-target="sapUserError"
             class="hidden mt-1 text-xs text-red-500">
            El usuario es requerido.
          </p>
        </div>

        <%# Campo: Compañía para probar credenciales %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Compañía para probar credenciales
          </label>
          <select data-user-profile-target="companySelect"
                  data-testid="company-select"
                  data-action="change->user-profile#onCompanyChange"
                  disabled
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent disabled:bg-gray-50 disabled:text-gray-400 disabled:cursor-not-allowed">
            <option value="">— Seleccione —</option>
          </select>
          <p class="mt-1 text-xs text-gray-400">Se usará la conexión SAP de esta compañía.</p>
        </div>

        <%# Campo: Contraseña de SAP %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Contraseña de SAP
          </label>
          <div class="relative">
            <input type="password"
                   data-user-profile-target="sapPassInput"
                   data-testid="sap-pass-input"
                   data-action="input->user-profile#onCredentialChange"
                   placeholder="Contraseña de SAP"
                   class="w-full border border-gray-300 rounded-lg px-3 py-2 pr-10 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
            <button type="button"
                    data-user-profile-target="togglePasswordBtn"
                    data-testid="toggle-password-btn"
                    data-action="click->user-profile#togglePasswordVisibility"
                    class="absolute inset-y-0 right-0 flex items-center px-3 text-gray-400 hover:text-gray-600 focus:outline-none"
                    aria-label="Mostrar/ocultar contraseña">
              <span data-user-profile-target="eyeIcon"
                    class="material-icons text-xl">visibility_off</span>
            </button>
          </div>
        </div>

        <%# Campo: Tipo de OC (condicional) %>
        <div data-user-profile-target="ocTypeSection"
             data-testid="oc-type-section"
             class="hidden">
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Tipo de OC
          </label>
          <select data-user-profile-target="ocTypeSelect"
                  data-testid="oc-type-select"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
            <option value="">— Seleccione —</option>
            <option value="1">Con numero de OC</option>
            <option value="2">Sin numero de OC</option>
          </select>
        </div>

      </div><%# /grid %>

      <%# ---------------------------------------------------------------- %>
      <%# ACCIONES %>
      <%# ---------------------------------------------------------------- %>
      <div class="flex justify-end items-center gap-3 mt-6 pt-5 border-t border-gray-100">

        <%# Botón: Probar credenciales %>
        <button type="button"
                data-user-profile-target="btnTestCredentials"
                data-testid="btn-test-credentials"
                data-action="click->user-profile#testCredentials"
                disabled
                class="flex items-center gap-2 px-4 py-2 rounded-lg border border-blue-400 text-blue-600 text-sm font-medium hover:bg-blue-50 transition-all duration-300 disabled:opacity-40 disabled:cursor-not-allowed">
          <span data-user-profile-target="testCredentialsIcon"
                class="material-icons text-base">wifi_tethering</span>
          <span data-user-profile-target="testCredentialsLabel">Probar credenciales</span>
        </button>

        <%# Botón: Actualizar %>
        <button type="submit"
                data-user-profile-target="btnUpdate"
                data-testid="btn-update"
                class="flex items-center gap-2 px-5 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
          <span class="material-icons text-base">update</span>
          <span>Actualizar</span>
        </button>

      </div>

    </form>
  </div>

  <%# ---------------------------------------------------------------- %>
  <%# TOAST (notificaciones) %>
  <%# ---------------------------------------------------------------- %>
  <div data-user-profile-target="toast"
       class="hidden fixed top-5 right-5 z-50 flex items-start gap-3 px-4 py-3 rounded-lg shadow-lg text-sm text-white max-w-sm transition-all duration-300">
    <span data-user-profile-target="toastIcon" class="material-icons text-base mt-0.5">info</span>
    <span data-user-profile-target="toastMessage" data-testid="toast-message"></span>
  </div>

  <%# Toast de error (alias para data-testid) %>
  <div data-testid="toast-error" class="hidden"></div>

  <%# ---------------------------------------------------------------- %>
  <%# MODAL DE ERROR %>
  <%# ---------------------------------------------------------------- %>
  <div data-user-profile-target="errorModal"
       data-testid="modal-error"
       class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40">
    <div class="bg-white rounded-xl shadow-xl p-6 max-w-sm w-full mx-4">
      <div class="flex items-center gap-3 mb-3">
        <span class="material-icons text-red-500 text-2xl">error</span>
        <h3 data-user-profile-target="modalTitle"
            data-testid="modal-title"
            class="text-base font-semibold text-gray-800"></h3>
      </div>
      <p data-user-profile-target="modalSubtitle"
         class="text-sm text-gray-600 mb-5"></p>
      <div class="flex justify-end">
        <button type="button"
                data-action="click->user-profile#closeModal"
                class="px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 transition-colors">
          Entendido
        </button>
      </div>
    </div>
  </div>

</div>
