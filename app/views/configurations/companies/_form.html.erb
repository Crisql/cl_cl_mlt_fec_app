<%# ============================================================ %>
<%# PANEL LATERAL DERECHO — Crear Conexión SAP %>
<%# Se abre desde el botón "add" del campo Conexión de SAP. %>
<%# Al crear exitosamente, el select se auto-setea con la nueva conexión. %>
<%# ============================================================ %>

<%# Backdrop %>
<div data-company-form-target="connPanelBackdrop"
     data-action="click->company-form#closeConnectionPanel"
     class="hidden fixed inset-0 z-40 bg-black/40">
</div>

<%# Panel deslizable desde la derecha %>
<div data-company-form-target="connPanel"
     class="fixed top-0 right-0 h-full w-full max-w-lg bg-white shadow-2xl z-50
            translate-x-full transition-transform duration-300 ease-in-out flex flex-col">

  <%# Header %>
  <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100 flex-shrink-0">
    <h3 class="text-base font-semibold text-gray-800">Nueva Conexión SAP</h3>
    <button type="button"
            data-action="click->company-form#closeConnectionPanel"
            class="p-1 text-gray-400 hover:text-gray-600 rounded hover:bg-gray-100 transition-colors">
      <span class="material-icons text-xl">close</span>
    </button>
  </div>

  <%# Cuerpo — campos del formulario %>
  <div class="flex-1 overflow-y-auto px-6 py-5">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

      <%# Servidor %>
      <div class="flex flex-col gap-1">
        <label class="text-xs font-medium text-gray-600">Servidor <span class="text-red-500">*</span></label>
        <input type="text"
               data-company-form-target="connServer"
               data-testid="conn-panel-server"
               placeholder="Servidor SAP"
               class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        <span data-company-form-target="connServerError" class="hidden text-xs text-red-500">El servidor es requerido.</span>
      </div>

      <%# Servidor de Licencias %>
      <div class="flex flex-col gap-1">
        <label class="text-xs font-medium text-gray-600">Servidor de Licencias</label>
        <input type="text"
               data-company-form-target="connLicenseServer"
               data-testid="conn-panel-license-server"
               placeholder="Servidor de Licencias"
               class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>

      <%# URL API %>
      <div class="flex flex-col gap-1">
        <label class="text-xs font-medium text-gray-600">URL API <span class="text-red-500">*</span></label>
        <input type="text"
               data-company-form-target="connApiUrl"
               data-testid="conn-panel-api-url"
               placeholder="https://servidor:50000"
               class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        <span data-company-form-target="connApiUrlError" class="hidden text-xs text-red-500">La URL de la API es requerida.</span>
      </div>

      <%# URL Crystal API %>
      <div class="flex flex-col gap-1">
        <label class="text-xs font-medium text-gray-600">URL Crystal API</label>
        <input type="text"
               data-company-form-target="connCrystalApiUrl"
               data-testid="conn-panel-crystal-api-url"
               placeholder="https://crystal.servidor.com"
               class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>

      <%# Tipo ODBC %>
      <div class="flex flex-col gap-1">
        <label class="text-xs font-medium text-gray-600">Tipo ODBC</label>
        <input type="text"
               data-company-form-target="connOdbcType"
               data-testid="conn-panel-odbc-type"
               placeholder="HDBODBC"
               class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>

      <%# Motor de Base de Datos %>
      <div class="flex flex-col gap-1">
        <label class="text-xs font-medium text-gray-600">Motor de Base de Datos <span class="text-red-500">*</span></label>
        <input type="text"
               data-company-form-target="connDbEngine"
               data-testid="conn-panel-db-engine"
               placeholder="hdb"
               class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        <span data-company-form-target="connDbEngineError" class="hidden text-xs text-red-500">El motor de base de datos es requerido.</span>
      </div>

      <%# Tipo de Servidor %>
      <div class="flex flex-col gap-1">
        <label class="text-xs font-medium text-gray-600">Tipo de Servidor</label>
        <input type="text"
               data-company-form-target="connServerType"
               data-testid="conn-panel-server-type"
               placeholder="HanaDb"
               class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>

      <%# Usuario de Base de Datos %>
      <div class="flex flex-col gap-1">
        <label class="text-xs font-medium text-gray-600">Usuario de Base de Datos <span class="text-red-500">*</span></label>
        <input type="text"
               data-company-form-target="connDbUser"
               data-testid="conn-panel-db-user"
               placeholder="sa"
               class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        <span data-company-form-target="connDbUserError" class="hidden text-xs text-red-500">El usuario de base de datos es requerido.</span>
      </div>

      <%# Contraseña de Base de Datos %>
      <div class="sm:col-span-2 flex flex-col gap-1">
        <label class="text-xs font-medium text-gray-600">Contraseña de Base de Datos <span class="text-red-500">*</span></label>
        <div class="relative">
          <input type="password"
                 data-company-form-target="connDbPass"
                 data-testid="conn-panel-db-pass"
                 placeholder="••••••••"
                 class="w-full border border-gray-300 rounded-lg px-3 py-2 pr-10 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          <button type="button"
                  data-action="click->company-form#toggleConnDbPass"
                  class="absolute right-2 top-1/2 -translate-y-1/2 p-1 text-gray-500 hover:text-gray-700">
            <span data-company-form-target="connDbPassEyeIcon" class="material-icons text-base">visibility_off</span>
          </button>
        </div>
        <span data-company-form-target="connDbPassError" class="hidden text-xs text-red-500">La contraseña es requerida.</span>
      </div>

      <%# Idiomas Soportados %>
      <div class="flex flex-col gap-1">
        <label class="text-xs font-medium text-gray-600">Idiomas Soportados (BoSuppLangs)</label>
        <input type="text"
               data-company-form-target="connBoSuppLangs"
               data-testid="conn-panel-bo-supp-langs"
               placeholder="93"
               class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>

      <%# DST %>
      <div class="flex flex-col gap-1">
        <label class="text-xs font-medium text-gray-600">DST</label>
        <input type="text"
               data-company-form-target="connDst"
               data-testid="conn-panel-dst"
               placeholder="DST"
               class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>

      <%# UseTrusted %>
      <div class="sm:col-span-2 flex items-center gap-2">
        <input type="checkbox"
               id="connUseTrusted"
               data-company-form-target="connUseTrusted"
               data-testid="conn-panel-use-trusted"
               class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500 cursor-pointer">
        <label for="connUseTrusted" class="text-sm text-gray-700 cursor-pointer">Usar Conexión de Confianza (Trusted)</label>
      </div>

    </div>
  </div>

  <%# Footer %>
  <div class="px-6 py-4 border-t border-gray-100 flex justify-end gap-3 flex-shrink-0">
    <button type="button"
            data-action="click->company-form#closeConnectionPanel"
            class="inline-flex items-center gap-1 px-4 py-2 border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 transition-colors">
      <span class="material-icons text-base">cancel</span>
      Cancelar
    </button>
    <button type="button"
            data-action="click->company-form#saveConnectionFromPanel"
            data-company-form-target="connSaveBtn"
            class="inline-flex items-center gap-1 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
      <span class="material-icons text-base">check</span>
      Crear conexión
    </button>
  </div>

</div>

