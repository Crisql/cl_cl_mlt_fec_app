<% content_for :title, "Compañías — FEC" %>
<% content_for :page_title, "Búsqueda de Compañías" %>

<div data-controller="companies"
     data-testid="companies-page"
     class="p-6 flex flex-col h-full">

  <%# ---------------------------------------------------------------- %>
  <%# FILTROS DE BÚSQUEDA %>
  <%# ---------------------------------------------------------------- %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-4">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 items-end">

      <div class="flex flex-col gap-1">
        <label class="text-xs font-medium text-gray-500 uppercase tracking-wide">Nombre Legal</label>
        <input type="text"
               data-companies-target="searchLegalName"
               data-testid="search-legal-name"
               placeholder="Nombre Legal"
               class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>

      <div class="flex flex-col gap-1">
        <label class="text-xs font-medium text-gray-500 uppercase tracking-wide">Nombre Comercial</label>
        <input type="text"
               data-companies-target="searchComercialName"
               data-testid="search-comercial-name"
               placeholder="Nombre Comercial"
               class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>

      <div class="flex flex-col gap-1">
        <label class="text-xs font-medium text-gray-500 uppercase tracking-wide">Identificación</label>
        <input type="text"
               inputmode="numeric"
               pattern="[0-9]*"
               data-companies-target="searchIdentification"
               data-testid="search-identification"
               placeholder="Identificación"
               class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>

      <div class="flex gap-2">
        <button type="button"
                data-action="click->companies#search"
                data-testid="btn-search"
                class="flex-1 inline-flex items-center justify-center gap-1 px-4 py-2 border border-blue-600 text-blue-600 text-sm font-medium rounded-lg hover:bg-blue-50 transition-colors">
          <span class="material-icons text-base">filter_alt</span>
          Consultar
        </button>

        <button type="button"
                data-companies-target="btnCreate"
                data-testid="btn-create-company"
                data-action="click->companies#navigateCreate"
                class="hidden flex-1 inline-flex items-center justify-center gap-1 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
          <span class="material-icons text-base">add</span>
          Crear
        </button>
      </div>
    </div>
  </div>

  <%# ---------------------------------------------------------------- %>
  <%# TABLA %>
  <%# ---------------------------------------------------------------- %>
  <div class="flex-1 bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden flex flex-col min-h-0">
    <div class="flex-1 overflow-auto">
      <table data-testid="companies-table"
             data-companies-target="table"
             class="w-full text-sm text-left text-gray-700">
        <thead class="text-xs text-gray-500 uppercase bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="px-4 py-3 font-medium">Nombre Legal</th>
            <th class="px-4 py-3 font-medium">Nombre Comercial</th>
            <th class="px-4 py-3 font-medium">Identificación</th>
            <th class="px-4 py-3 font-medium text-center">Compañía Favorita</th>
            <th class="px-4 py-3 font-medium">Activa</th>
            <th class="px-4 py-3 font-medium w-24">Acciones</th>
          </tr>
        </thead>
        <tbody data-companies-target="tbody"
               data-testid="companies-tbody">
          <%# Filas inyectadas dinámicamente por Stimulus %>
        </tbody>
      </table>
    </div>

    <%# Estado vacío %>
    <div data-companies-target="emptyState"
         data-testid="empty-state"
         class="hidden py-12 text-center text-gray-400 text-sm">
      <span class="material-icons text-3xl mb-2 block">business</span>
      No se encontraron compañías
    </div>

    <%# Skeleton de carga %>
    <div data-companies-target="loadingState"
         class="hidden py-8 text-center text-gray-400 text-sm">
      <span class="material-icons animate-spin text-2xl mb-2 block">refresh</span>
      Cargando compañías...
    </div>

    <%# PAGINACIÓN %>
    <div data-companies-target="pagination"
         data-testid="pagination"
         class="hidden border-t border-gray-100 px-4 py-3 flex items-center justify-between text-sm text-gray-600">

      <div class="flex items-center gap-2">
        <span class="text-xs text-gray-500">Filas por página:</span>
        <select data-companies-target="pageSizeSelect"
                data-testid="page-size-select"
                data-action="change->companies#onPageSizeChange"
                class="border border-gray-300 rounded px-2 py-1 text-xs focus:outline-none focus:ring-1 focus:ring-blue-500">
          <option value="5">5</option>
          <option value="10">10</option>
          <option value="15">15</option>
        </select>
      </div>

      <div class="flex items-center gap-3">
        <span data-companies-target="pageInfo" class="text-xs text-gray-500"></span>

        <div class="flex items-center gap-1">
          <button type="button"
                  data-action="click->companies#prevPage"
                  data-companies-target="prevBtn"
                  data-testid="btn-prev-page"
                  class="p-1 rounded hover:bg-gray-100 disabled:opacity-40 disabled:cursor-not-allowed transition-colors"
                  disabled>
            <span class="material-icons text-base">chevron_left</span>
          </button>

          <span data-companies-target="currentPage"
                data-testid="current-page"
                class="text-xs font-medium px-2">1</span>

          <button type="button"
                  data-action="click->companies#nextPage"
                  data-companies-target="nextBtn"
                  data-testid="btn-next-page"
                  class="p-1 rounded hover:bg-gray-100 disabled:opacity-40 disabled:cursor-not-allowed transition-colors">
            <span class="material-icons text-base">chevron_right</span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <%# ---------------------------------------------------------------- %>
  <%# MODAL: Confirmación favorita %>
  <%# ---------------------------------------------------------------- %>
  <div data-companies-target="confirmModal"
       class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40">
    <div class="bg-white rounded-xl shadow-xl p-6 w-full max-w-sm mx-4">
      <h3 class="text-base font-semibold text-gray-800 mb-2">Confirmar</h3>
      <p class="text-sm text-gray-600 mb-6">¿Desea establecer esta compañía como favorita?</p>
      <div class="flex justify-end gap-3">
        <button type="button"
                data-action="click->companies#cancelFavorite"
                class="px-4 py-2 text-sm text-gray-600 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
          Cancelar
        </button>
        <button type="button"
                data-action="click->companies#confirmFavorite"
                class="px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors">
          Confirmar
        </button>
      </div>
    </div>
  </div>

  <%# ---------------------------------------------------------------- %>
  <%# MODAL: Error genérico %>
  <%# ---------------------------------------------------------------- %>
  <div data-companies-target="errorModal"
       data-testid="error-modal"
       class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40">
    <div class="bg-white rounded-xl shadow-xl p-6 w-full max-w-sm mx-4">
      <div class="flex items-center gap-3 mb-4">
        <span class="material-icons text-red-500 text-2xl">error_outline</span>
        <h3 data-companies-target="errorTitle"
            class="text-base font-semibold text-gray-800"></h3>
      </div>
      <p data-companies-target="errorSubtitle"
         class="text-sm text-gray-600 mb-6"></p>
      <div class="flex justify-end">
        <button type="button"
                data-action="click->companies#closeErrorModal"
                class="px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors">
          Aceptar
        </button>
      </div>
    </div>
  </div>

  <%# ---------------------------------------------------------------- %>
  <%# TOAST %>
  <%# ---------------------------------------------------------------- %>
  <div data-companies-target="toast"
       data-testid="toast"
       class="hidden fixed top-4 right-4 z-50 flex items-center gap-3 px-4 py-3 rounded-lg shadow-lg text-white text-sm font-medium min-w-64 max-w-sm">
    <span data-companies-target="toastIcon" class="material-icons text-base"></span>
    <span data-companies-target="toastMessage"></span>
  </div>

</div>
