<% content_for :title, "Conexiones SAP" %>
<% content_for :page_title, "Gestión de Conexiones SAP" %>

<div data-controller="connections"
     data-testid="connections-page"
     class="p-6 flex flex-col h-full">

  <%# ---------------------------------------------------------------- %>
  <%# HEADER: búsqueda + botones %>
  <%# ---------------------------------------------------------------- %>
  <div class="mb-4 bg-white rounded-xl shadow-sm border border-gray-100 p-4 flex-shrink-0">
    <div class="flex flex-wrap gap-3 items-end">

      <%# Servidor %>
      <div class="flex flex-col gap-1 flex-1 min-w-[180px]">
        <label class="text-xs font-medium text-gray-600">Servidor</label>
        <input type="text"
               data-connections-target="inputServer"
               data-testid="input-server"
               placeholder="Servidor"
               class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>

      <%# URL API %>
      <div class="flex flex-col gap-1 flex-1 min-w-[180px]">
        <label class="text-xs font-medium text-gray-600">URL API</label>
        <input type="text"
               data-connections-target="inputApiUrl"
               data-testid="input-api-url"
               placeholder="URL API"
               class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>

      <%# Botón Consultar %>
      <button type="button"
              data-testid="btn-search"
              data-action="click->connections#search"
              class="inline-flex items-center gap-1 px-4 py-2 border border-blue-600 text-blue-600 text-sm font-medium rounded-lg hover:bg-blue-50 transition-colors">
        <span class="material-icons text-base">filter_alt</span>
        Consultar
      </button>

      <%# Botón Crear (condicional por permiso) %>
      <button type="button"
              data-connections-target="btnCreate"
              data-testid="btn-create"
              data-action="click->connections#goToNew"
              class="hidden inline-flex items-center gap-1 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
        <span class="material-icons text-base">add</span>
        Crear
      </button>

    </div>
  </div>

  <%# ---------------------------------------------------------------- %>
  <%# TABLA DE CONEXIONES (Tabulator full-height, paginación remota) %>
  <%# ---------------------------------------------------------------- %>
  <div class="flex-1 min-h-0 bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div data-connections-target="table" data-testid="connections-table" class="h-full"></div>
  </div>

  <%# ---------------------------------------------------------------- %>
  <%# MODAL DE ERROR %>
  <%# ---------------------------------------------------------------- %>
  <div data-connections-target="errorModal"
       class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40">
    <div class="bg-white rounded-xl shadow-xl p-6 w-full max-w-sm mx-4">
      <div class="flex items-center gap-3 mb-4">
        <span class="material-icons text-red-500 text-2xl">error_outline</span>
        <h3 data-connections-target="errorTitle"
            class="text-base font-semibold text-gray-800"></h3>
      </div>
      <p data-connections-target="errorSubtitle"
         class="text-sm text-gray-600 mb-6 break-words"></p>
      <div class="flex justify-end">
        <button type="button"
                data-action="click->connections#closeErrorModal"
                class="px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors">
          Aceptar
        </button>
      </div>
    </div>
  </div>

</div>
