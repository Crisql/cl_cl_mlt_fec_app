<% content_for :title, "Conexiones SAP" %>
<% content_for :page_title, "Gestión de Conexiones SAP" %>

<div data-controller="connections"
     data-testid="connections-page"
     class="p-6 flex flex-col h-full">

  <%# ---------------------------------------------------------------- %>
  <%# HEADER: búsqueda + botones %>
  <%# ---------------------------------------------------------------- %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-4 flex-shrink-0">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 items-end">

      <%# Servidor %>
      <div class="flex flex-col gap-1">
        <label class="text-xs font-medium text-gray-500 uppercase tracking-wide">Servidor</label>
        <input type="text"
               data-connections-target="inputServer"
               data-testid="input-server"
               placeholder="Servidor"
               class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>

      <%# URL API %>
      <div class="flex flex-col gap-1">
        <label class="text-xs font-medium text-gray-500 uppercase tracking-wide">URL API</label>
        <input type="text"
               data-connections-target="inputApiUrl"
               data-testid="input-api-url"
               placeholder="URL API"
               class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>

      <%# Botones Consultar / Crear %>
      <div class="flex gap-2">
        <button type="button"
                data-testid="btn-search"
                data-action="click->connections#search"
                class="flex-1 inline-flex items-center justify-center gap-1 px-4 py-2 border border-blue-600 text-blue-600 text-sm font-medium rounded-lg hover:bg-blue-50 transition-colors">
          <span class="material-icons text-base">filter_alt</span>
          Consultar
        </button>

        <button type="button"
                data-connections-target="btnCreate"
                data-testid="btn-create"
                data-action="click->connections#openCreatePanel"
                class="hidden flex-1 inline-flex items-center justify-center gap-1 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
          <span class="material-icons text-base">add</span>
          Nueva Conexión
        </button>
      </div>

    </div>
  </div>

  <%# ---------------------------------------------------------------- %>
  <%# TABLA DE CONEXIONES (Tabulator full-height, paginación remota) %>
  <%# ---------------------------------------------------------------- %>
  <div class="flex-1 min-h-0 bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div data-connections-target="table" data-testid="connections-table" class="h-full"></div>
  </div>

  <%# ================================================================ %>
  <%# PANEL LATERAL DERECHO — Crear / Editar Conexión SAP %>
  <%# Reemplaza la navegación a /connections/new y /:id/edit (CLAUDE.md §8). %>
  <%# ================================================================ %>

  <%# Backdrop %>
  <div data-connections-target="panelBackdrop"
       data-action="click->connections#closePanel"
       class="hidden fixed inset-0 z-40 bg-black/40"></div>

  <%# Panel deslizable desde la derecha %>
  <div data-connections-target="panel"
       data-testid="connection-panel"
       class="fixed top-0 right-0 h-full w-full max-w-lg bg-white shadow-2xl z-50
              translate-x-full transition-transform duration-300 ease-in-out flex flex-col">

    <%# Header %>
    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100 flex-shrink-0">
      <h3 data-connections-target="panelTitle" class="text-base font-semibold text-gray-800">Nueva Conexión SAP</h3>
      <button type="button"
              data-action="click->connections#closePanel"
              data-testid="connection-panel-close"
              class="p-1 text-gray-400 hover:text-gray-600 rounded hover:bg-gray-100 transition-colors">
        <span class="material-icons text-xl">close</span>
      </button>
    </div>

    <%# Cuerpo — campos del formulario %>
    <div class="flex-1 overflow-y-auto px-6 py-5">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

        <%# Servidor %>
        <div class="flex flex-col gap-1">
          <label class="text-xs font-medium text-gray-600">Servidor <span class="text-red-500">*</span></label>
          <input type="text"
                 data-connections-target="fServer"
                 data-testid="panel-input-server"
                 placeholder="Servidor SAP"
                 class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          <span data-connections-target="fServerError" class="hidden text-xs text-red-500">El servidor es requerido.</span>
        </div>

        <%# Servidor de Licencias %>
        <div class="flex flex-col gap-1">
          <label class="text-xs font-medium text-gray-600">Servidor de Licencias</label>
          <input type="text"
                 data-connections-target="fLicenseServer"
                 data-testid="panel-input-license-server"
                 placeholder="Servidor de Licencias"
                 class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>

        <%# URL API %>
        <div class="flex flex-col gap-1">
          <label class="text-xs font-medium text-gray-600">URL API <span class="text-red-500">*</span></label>
          <input type="text"
                 data-connections-target="fApiUrl"
                 data-testid="panel-input-api-url"
                 placeholder="https://servidor:50000"
                 class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          <span data-connections-target="fApiUrlError" class="hidden text-xs text-red-500">La URL de la API es requerida.</span>
        </div>

        <%# URL Crystal API %>
        <div class="flex flex-col gap-1">
          <label class="text-xs font-medium text-gray-600">URL Crystal API</label>
          <input type="text"
                 data-connections-target="fCrystalApiUrl"
                 data-testid="panel-input-crystal-api-url"
                 placeholder="https://crystal.servidor.com"
                 class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>

        <%# Tipo ODBC %>
        <div class="flex flex-col gap-1">
          <label class="text-xs font-medium text-gray-600">Tipo ODBC</label>
          <input type="text"
                 data-connections-target="fOdbcType"
                 data-testid="panel-input-odbc-type"
                 placeholder="HDBODBC"
                 class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>

        <%# Motor de Base de Datos %>
        <div class="flex flex-col gap-1">
          <label class="text-xs font-medium text-gray-600">Motor de Base de Datos <span class="text-red-500">*</span></label>
          <input type="text"
                 data-connections-target="fDbEngine"
                 data-testid="panel-input-db-engine"
                 placeholder="hdb"
                 class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          <span data-connections-target="fDbEngineError" class="hidden text-xs text-red-500">El motor de base de datos es requerido.</span>
        </div>

        <%# Tipo de Servidor %>
        <div class="flex flex-col gap-1">
          <label class="text-xs font-medium text-gray-600">Tipo de Servidor</label>
          <input type="text"
                 data-connections-target="fServerType"
                 data-testid="panel-input-server-type"
                 placeholder="HanaDb"
                 class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>

        <%# Usuario de Base de Datos %>
        <div class="flex flex-col gap-1">
          <label class="text-xs font-medium text-gray-600">Usuario de Base de Datos <span class="text-red-500">*</span></label>
          <input type="text"
                 data-connections-target="fDbUser"
                 data-testid="panel-input-db-user"
                 placeholder="sa"
                 class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          <span data-connections-target="fDbUserError" class="hidden text-xs text-red-500">El usuario de base de datos es requerido.</span>
        </div>

        <%# Contraseña de Base de Datos %>
        <div class="sm:col-span-2 flex flex-col gap-1">
          <label class="text-xs font-medium text-gray-600">
            Contraseña de Base de Datos<span data-connections-target="fDbPassRequired" class="text-red-500"> *</span>
          </label>
          <div class="relative">
            <input type="password"
                   data-connections-target="fDbPass"
                   data-testid="panel-input-db-pass"
                   placeholder="••••••••"
                   class="w-full border border-gray-300 rounded-lg px-3 py-2 pr-10 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            <button type="button"
                    data-action="click->connections#togglePassword"
                    data-testid="panel-btn-toggle-pass"
                    class="absolute right-2 top-1/2 -translate-y-1/2 p-1 text-gray-500 hover:text-gray-700">
              <span data-connections-target="togglePassIcon" class="material-icons text-base">visibility_off</span>
            </button>
          </div>
          <span data-connections-target="fDbPassError" class="hidden text-xs text-red-500">La contraseña es requerida.</span>
        </div>

        <%# Idiomas Soportados %>
        <div class="flex flex-col gap-1">
          <label class="text-xs font-medium text-gray-600">Idiomas Soportados (BoSuppLangs)</label>
          <input type="text"
                 data-connections-target="fBoSuppLangs"
                 data-testid="panel-input-bo-supp-langs"
                 placeholder="93"
                 class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>

        <%# DST %>
        <div class="flex flex-col gap-1">
          <label class="text-xs font-medium text-gray-600">DST</label>
          <input type="text"
                 data-connections-target="fDst"
                 data-testid="panel-input-dst"
                 placeholder="DST"
                 class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>

        <%# UseTrusted %>
        <div class="sm:col-span-2 flex items-center gap-2">
          <input type="checkbox"
                 id="connUseTrusted"
                 data-connections-target="fUseTrusted"
                 data-testid="panel-input-use-trusted"
                 class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500 cursor-pointer">
          <label for="connUseTrusted" class="text-sm text-gray-700 cursor-pointer">Usar Conexión de Confianza (Trusted)</label>
        </div>

      </div>
    </div>

    <%# Footer %>
    <div class="px-6 py-4 border-t border-gray-100 flex justify-end gap-3 flex-shrink-0">
      <button type="button"
              data-action="click->connections#closePanel"
              data-testid="panel-btn-cancel"
              class="inline-flex items-center gap-1 px-4 py-2 border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 transition-colors">
        <span class="material-icons text-base">cancel</span>
        Cancelar
      </button>
      <button type="button"
              data-action="click->connections#savePanel"
              data-connections-target="submitBtn"
              data-testid="panel-btn-submit"
              class="inline-flex items-center gap-1 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
        <span data-connections-target="submitIcon" class="material-icons text-base">check</span>
        <span data-connections-target="submitLabel">Crear conexión</span>
      </button>
    </div>

  </div>

</div>
