<% content_for :title, "Grupos" %>
<% content_for :page_title, "Grupos" %>

<div data-controller="group"
     data-testid="group-page"
     class="p-6 flex flex-col h-full relative">

  <%# Loader a nivel de sección (sin texto) %>
  <div data-group-target="sectionLoader"
       class="hidden absolute inset-0 z-40 flex items-center justify-center bg-white/60">
    <svg width="40" height="40" viewBox="0 0 50 50" aria-hidden="true">
      <circle cx="25" cy="25" r="20" fill="none" stroke="#e5e7eb" stroke-width="5"></circle>
      <circle cx="25" cy="25" r="20" fill="none" stroke="#2563eb" stroke-width="5"
              stroke-linecap="round" stroke-dasharray="80 200">
        <animateTransform attributeName="transform" attributeType="XML" type="rotate"
                          from="0 25 25" to="360 25 25" dur="0.8s" repeatCount="indefinite"></animateTransform>
      </circle>
    </svg>
  </div>

  <%# ---------------------------------------------------------------- %>
  <%# CARD: Datos de la Cuenta %>
  <%# ---------------------------------------------------------------- %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-4 flex-shrink-0">
    <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-4">
      Datos de la Cuenta
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">

      <%# Nombre (readonly) %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Nombre</label>
        <input type="text"
               id="GroupName"
               name="GroupName"
               data-group-target="groupName"
               data-field="GroupName"
               data-testid="input-group-name"
               readonly
               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                      bg-gray-50 cursor-default outline-none focus:ring-2 focus:ring-blue-500">
      </div>

      <%# Descripción (editable) %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Descripción</label>
        <input type="text"
               id="GroupDescription"
               name="GroupDescription"
               data-group-target="groupDescription"
               data-field="GroupDescription"
               data-testid="input-group-description"
               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                      focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
      </div>

      <%# Formato de Impresión por Defecto — matSuffix (CLAUDE.md §4) %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Formato de Impresión por Defecto
        </label>
        <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden
                    focus-within:ring-2 focus-within:ring-blue-500 bg-gray-50">
          <input type="text"
                 id="DefaultPrintFormatPath"
                 name="DefaultPrintFormatPath"
                 data-group-target="printFormatInput"
                 data-field="DefaultPrintFormatPath"
                 data-testid="input-print-format"
                 readonly
                 placeholder="Seleccione un archivo .rpt"
                 class="flex-1 px-3 py-2 text-sm bg-transparent outline-none cursor-default">

          <%# Input file oculto %>
          <input type="file"
                 data-group-target="fileInput"
                 data-action="change->group#onFileSelected"
                 class="hidden">

          <%# Botón Adjuntar %>
          <button type="button"
                  data-action="click->group#triggerFileInput"
                  data-tooltip="Adjuntar archivo .rpt"
                  title="Adjuntar archivo .rpt"
                  class="self-stretch flex items-center px-2 border-l border-gray-200
                         text-gray-500 hover:bg-gray-100 hover:text-gray-700 transition-colors flex-shrink-0">
            <span class="material-icons text-base leading-none">attach_file</span>
          </button>

          <%# Botón Descargar — visible solo con permiso %>
          <button type="button"
                  data-group-target="downloadFormatBtn"
                  data-action="click->group#downloadPrintFormat"
                  data-tooltip="Descargar formato"
                  title="Descargar"
                  class="hidden self-stretch flex items-center px-2 border-l border-gray-200
                         text-gray-500 hover:bg-gray-100 hover:text-gray-700 transition-colors flex-shrink-0">
            <span class="material-icons text-base leading-none">download</span>
          </button>
        </div>
      </div>

    </div>

    <%# Botones de acción %>
    <div class="flex justify-end gap-3 flex-wrap">

      <%# Actualizar — visible con permiso Update %>
      <button type="button"
              data-group-target="updateBtn"
              data-action="click->group#updateGroup"
              data-testid="btn-update"
              class="hidden inline-flex items-center gap-1 px-4 py-2 bg-blue-600 text-white
                     text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
        <span class="material-icons text-base">refresh</span>
        Actualizar
      </button>

      <%# Restablecer Formato — visible con permiso Update %>
      <button type="button"
              data-group-target="resetFormatBtn"
              data-action="click->group#resetPrintFormat"
              data-testid="btn-reset-format"
              title="Configura el formato de impresión predeterminado definido en configuraciones generales."
              class="hidden inline-flex items-center gap-1 px-4 py-2 bg-blue-600 text-white
                     text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
        <span class="material-icons text-base">refresh</span>
        Restablecer Formato
      </button>

      <%# Crear — visible con permiso Create %>
      <button type="button"
              data-group-target="createBtn"
              data-action="click->group#openCreatePanel"
              data-testid="btn-create"
              class="hidden inline-flex items-center gap-1 px-4 py-2 bg-blue-600 text-white
                     text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
        <span class="material-icons text-base">add</span>
        Nuevo Grupo
      </button>

    </div>
  </div>

  <%# ---------------------------------------------------------------- %>
  <%# TABS: Usuarios / Compañías %>
  <%# ---------------------------------------------------------------- %>
  <div class="flex-1 min-h-0 flex flex-col bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">

    <%# Tab headers %>
    <div class="flex border-b border-gray-200 flex-shrink-0 px-4">
      <button type="button"
              data-group-target="tabUsers"
              data-action="click->group#showTabUsers"
              data-testid="tab-users"
              class="px-4 py-3 text-sm font-medium text-blue-600 border-b-2 border-blue-600 -mb-px
                     hover:text-blue-700 transition-colors">
        Usuarios de la Cuenta
      </button>
      <button type="button"
              data-group-target="tabCompanies"
              data-action="click->group#showTabCompanies"
              data-testid="tab-companies"
              class="px-4 py-3 text-sm font-medium text-gray-500 border-b-2 border-transparent -mb-px
                     hover:text-gray-700 transition-colors">
        Compañías de la Cuenta
      </button>
    </div>

    <%# Panel Usuarios %>
    <div data-group-target="panelUsers"
         data-testid="panel-users"
         class="flex-1 min-h-0">
      <div data-group-target="table"
           data-testid="table-users"
           class="h-full"></div>
    </div>

    <%# Panel Compañías (oculto por defecto) %>
    <div data-group-target="panelCompanies"
         data-testid="panel-companies"
         class="hidden flex-1 min-h-0">
      <div data-group-target="companiesTable"
           data-testid="table-companies"
           class="h-full"></div>
    </div>

  </div>

  <%# ---------------------------------------------------------------- %>
  <%# PANEL LATERAL: Crear Grupo %>
  <%# ---------------------------------------------------------------- %>
  <div data-group-target="panelBackdrop"
       data-action="click->group#closeCreatePanel"
       class="hidden fixed inset-0 z-40 bg-black/40">
  </div>

  <div data-group-target="createPanel"
       class="fixed top-0 right-0 h-full w-full max-w-md bg-white shadow-2xl z-50
              translate-x-full transition-transform duration-300 ease-in-out flex flex-col">

    <%# Header %>
    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100 flex-shrink-0">
      <h3 class="text-base font-semibold text-gray-800">Creación de Grupo</h3>
      <button type="button"
              data-action="click->group#closeCreatePanel"
              class="p-1 text-gray-400 hover:text-gray-600 rounded hover:bg-gray-100 transition-colors">
        <span class="material-icons text-xl">close</span>
      </button>
    </div>

    <%# Cuerpo %>
    <div class="flex-1 overflow-y-auto px-6 py-5 flex flex-col gap-4">

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Nombre del grupo <span class="text-red-500">*</span>
        </label>
        <input type="text"
               data-group-target="newGroupName"
               data-field="GroupName"
               data-testid="input-new-group-name"
               placeholder="Nombre del grupo"
               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                      focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
        <p data-group-target="newGroupNameError"
           class="hidden text-xs text-red-600 mt-1">El nombre del grupo es requerido.</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Descripción del grupo
        </label>
        <input type="text"
               data-group-target="newGroupDescription"
               data-testid="input-new-group-description"
               placeholder="Descripción del grupo"
               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                      focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
      </div>

    </div>

    <%# Footer %>
    <div class="px-6 py-4 border-t border-gray-100 flex justify-end gap-3 flex-shrink-0">
      <button type="button"
              data-action="click->group#closeCreatePanel"
              data-testid="btn-panel-cancel"
              class="inline-flex items-center gap-1 px-4 py-2 border border-gray-300 text-gray-700
                     text-sm font-medium rounded-lg hover:bg-gray-50 transition-colors">
        <span class="material-icons text-base">cancel</span>
        Cancelar
      </button>
      <button type="button"
              data-group-target="createSubmitBtn"
              data-action="click->group#createGroup"
              data-testid="btn-panel-create"
              disabled
              class="inline-flex items-center gap-1 px-4 py-2 bg-blue-600 text-white text-sm
                     font-medium rounded-lg hover:bg-blue-700 transition-colors
                     disabled:opacity-50 disabled:cursor-not-allowed">
        <span class="material-icons text-base">check</span>
        Crear
      </button>
    </div>

  </div>


</div>
