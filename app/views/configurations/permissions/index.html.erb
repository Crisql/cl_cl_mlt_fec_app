<% content_for :title, "Permisos" %>
<% content_for :page_title, "Permisos" %>

<div data-controller="permissions"
     data-permissions-by-role-url-value="/configurations/permissions/by-role"
     data-permissions-global-url-value="/configurations/permissions/global"
     data-testid="permissions-page"
     class="flex flex-col h-full">

  <%# ---------------------------------------------------------------- %>
  <%# TABS HEADER %>
  <%# ---------------------------------------------------------------- %>
  <div class="border-b border-gray-200 bg-white px-6" data-testid="tabs-header">
    <nav class="flex space-x-0" role="tablist">
      <button
        data-permissions-target="tabByRole"
        data-action="click->permissions#switchToByRole"
        data-testid="tab-by-role"
        role="tab"
        aria-selected="false"
        class="tab-btn px-6 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 transition-colors focus:outline-none hidden">
        Permisos por Rol
      </button>
      <button
        data-permissions-target="tabGlobal"
        data-action="click->permissions#switchToGlobal"
        data-testid="tab-global"
        role="tab"
        aria-selected="false"
        class="tab-btn px-6 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 transition-colors focus:outline-none hidden">
        Permisos Globales
      </button>
    </nav>
  </div>

  <%# ---------------------------------------------------------------- %>
  <%# TAB CONTENT %>
  <%# ---------------------------------------------------------------- %>
  <div class="flex-1 min-h-0 flex flex-col">

    <%# === PANEL: PERMISOS POR ROL === %>
    <div data-permissions-target="panelByRole"
         data-testid="panel-by-role"
         class="hidden p-6 flex flex-col h-full">

      <%# Selector de rol + badge cambios %>
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 mb-5">
        <div class="flex items-center gap-5 flex-wrap">
          <div class="flex-1 min-w-48 max-w-sm">
            <label class="block text-xs font-medium text-gray-500 mb-1">Seleccione el rol</label>
            <select data-permissions-target="roleSelect"
                    data-action="change->permissions#onRoleChange"
                    data-testid="role-select"
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
              <option value="">— Seleccione —</option>
            </select>
          </div>
          <div data-permissions-target="changesBadge"
               data-testid="changes-badge"
               class="hidden flex items-center gap-2 bg-gray-100 rounded-full px-4 py-2">
            <span class="text-xs text-gray-500">Cambios pendientes:</span>
            <span data-permissions-target="changesBadgeValue"
                  data-testid="changes-badge-value"
                  class="font-bold text-gray-400 text-sm min-w-6 text-center">0</span>
          </div>
        </div>
      </div>

      <%# Drag & Drop panel %>
      <div data-permissions-target="dragDropPanel"
           data-testid="drag-drop-panel"
           class="hidden flex-1 min-h-0 flex flex-col">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex flex-col flex-1 min-h-0">

          <%# Las dos listas %>
          <div class="grid grid-cols-[1fr_auto_1fr] gap-6 mb-4 flex-1 min-h-0">

            <%# Lista disponibles %>
            <div class="flex flex-col min-h-0">
              <div class="flex items-center gap-3 px-4 py-3 rounded-t-lg text-white"
                   style="background: linear-gradient(135deg, #4db8e8 0%, #0082c0 100%)">
                <span class="material-icons text-xl">security</span>
                <h3 class="flex-1 text-sm font-medium m-0">Permisos Disponibles</h3>
                <span data-permissions-target="unassignedCount"
                      class="bg-white/30 px-3 py-0.5 rounded-full text-xs font-bold">0</span>
                <button data-action="click->permissions#assignAll"
                        data-permissions-target="btnAssignAll"
                        data-testid="btn-assign-all"
                        class="text-white hover:bg-white/20 rounded p-0.5 transition-colors disabled:opacity-50"
                        title="Asignar todos">
                  <span class="material-icons">chevron_right</span>
                </button>
              </div>
              <div data-permissions-target="unassignedList"
                   data-testid="unassigned-list"
                   data-drop-zone="unassigned"
                   data-action="dragover->permissions#onDragOver drop->permissions#onDrop"
                   class="flex-1 min-h-0 border-2 border-dashed border-gray-200 border-t-0 rounded-b-lg p-3 bg-gray-50 overflow-y-auto transition-colors">
                <div data-permissions-target="emptyUnassigned"
                     class="flex flex-col items-center justify-center h-full text-gray-400 py-10">
                  <span class="material-icons text-5xl opacity-40 mb-3">check_circle</span>
                  <p class="text-xs">Todos los permisos están asignados</p>
                </div>
              </div>
            </div>

            <%# Indicador central %>
            <div class="flex flex-col items-center justify-center gap-2 py-5">
              <span class="material-icons text-5xl text-gray-300 animate-pulse">swap_horiz</span>
              <p class="text-xs text-gray-400 text-center max-w-20">Arrastra para asignar/desasignar</p>
            </div>

            <%# Lista asignados %>
            <div class="flex flex-col min-h-0">
              <div class="flex items-center gap-3 px-4 py-3 rounded-t-lg text-white"
                   style="background: linear-gradient(135deg, #0082c0 0%, #005a85 100%)">
                <button data-action="click->permissions#unassignAll"
                        data-permissions-target="btnUnassignAll"
                        data-testid="btn-unassign-all"
                        class="text-white hover:bg-white/20 rounded p-0.5 transition-colors disabled:opacity-50"
                        title="Desasignar todos">
                  <span class="material-icons">chevron_left</span>
                </button>
                <span class="material-icons text-xl">verified_user</span>
                <h3 class="flex-1 text-sm font-medium m-0">Permisos Asignados</h3>
                <span data-permissions-target="assignedCount"
                      class="bg-white/30 px-3 py-0.5 rounded-full text-xs font-bold">0</span>
              </div>
              <div data-permissions-target="assignedList"
                   data-testid="assigned-list"
                   data-drop-zone="assigned"
                   data-action="dragover->permissions#onDragOver drop->permissions#onDrop"
                   class="flex-1 min-h-0 border-2 border-dashed border-gray-200 border-t-0 rounded-b-lg p-3 bg-gray-50 overflow-y-auto transition-colors">
                <div data-permissions-target="emptyAssigned"
                     class="flex flex-col items-center justify-center h-full text-gray-400 py-10">
                  <span class="material-icons text-5xl opacity-40 mb-3">inbox</span>
                  <p class="text-xs">No hay permisos asignados</p>
                </div>
              </div>
            </div>
          </div>

          <%# Resumen de cambios %>
          <div data-permissions-target="changesSummary"
               data-testid="changes-summary"
               class="hidden border-t border-gray-100 pt-4 mb-4">
            <div class="flex flex-col gap-3">
              <div data-permissions-target="assignSummaryRow"
                   class="hidden items-center gap-3 text-sm">
                <span class="material-icons text-green-500 text-xl">add_circle</span>
                <span><strong data-permissions-target="assignCount" data-testid="assign-count">0</strong> permiso(s) para asignar</span>
              </div>
              <div data-permissions-target="unassignSummaryRow"
                   class="hidden items-center gap-3 text-sm">
                <span class="material-icons text-red-500 text-xl">remove_circle</span>
                <span><strong data-permissions-target="unassignCount">0</strong> permiso(s) para desasignar</span>
              </div>
            </div>
          </div>

          <%# Botones de acción %>
          <div class="flex justify-end gap-3 pt-4 border-t border-gray-100">
            <button data-action="click->permissions#cancelChanges"
                    data-permissions-target="btnCancel"
                    data-testid="btn-cancel"
                    disabled
                    class="flex items-center gap-2 px-5 py-2 rounded-lg border border-red-300 text-red-600 text-sm font-medium hover:bg-red-50 transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
              <span class="material-icons text-base">close</span>
              Cancelar Cambios
            </button>
            <button data-action="click->permissions#saveChanges"
                    data-permissions-target="btnSave"
                    data-testid="btn-save"
                    disabled
                    class="flex items-center gap-2 px-5 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
              <span class="material-icons text-base">save</span>
              Guardar Cambios
            </button>
          </div>
        </div>
      </div>

      <%# Empty state sin rol %>
      <div data-permissions-target="emptyRoleState"
           data-testid="empty-role-state"
           class="bg-white rounded-xl shadow-sm border border-gray-100 p-16 text-center text-gray-400">
        <span class="material-icons text-9xl opacity-30 mb-5 block">assignment_ind</span>
        <h2 class="text-2xl font-light mb-3">Selecciona un rol</h2>
        <p class="text-base">Elige un rol de la lista para gestionar sus permisos</p>
      </div>
    </div>

    <%# === PANEL: PERMISOS GLOBALES === %>
    <div data-permissions-target="panelGlobal"
         data-testid="panel-global"
         class="hidden p-6 flex flex-col h-full">

      <%# Autocomplete usuario + badge %>
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 mb-5">
        <div class="flex items-center gap-5 flex-wrap">
          <div class="flex-1 min-w-64 max-w-sm relative">
            <label class="block text-xs font-medium text-gray-500 mb-1">Buscar Usuario</label>
            <div class="relative">
              <input type="text"
                     data-permissions-target="userSearch"
                     data-action="input->permissions#onUserInput focus->permissions#onUserFocus blur->permissions#onUserBlur"
                     data-testid="user-search"
                     placeholder="Escribe para buscar..."
                     autocomplete="off"
                     class="w-full border border-gray-300 rounded-lg px-3 py-2 pr-9 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
              <span class="material-icons absolute right-2 top-1/2 -translate-y-1/2 text-gray-400 text-lg pointer-events-none">search</span>
            </div>
            <%# Dropdown autocomplete %>
            <div data-permissions-target="userDropdown"
                 class="hidden absolute z-50 w-full mt-1 bg-white border border-gray-200 rounded-lg shadow-lg max-h-48 overflow-y-auto">
            </div>
          </div>
          <div data-permissions-target="changesBadgeGlobal"
               class="hidden flex items-center gap-2 bg-gray-100 rounded-full px-4 py-2">
            <span class="text-xs text-gray-500">Cambios pendientes:</span>
            <span data-permissions-target="changesBadgeValueGlobal"
                  class="font-bold text-gray-400 text-sm min-w-6 text-center">0</span>
          </div>
        </div>
      </div>

      <%# Drag & Drop panel global %>
      <div data-permissions-target="dragDropPanelGlobal"
           data-testid="drag-drop-panel-global"
           class="hidden flex-1 min-h-0 flex flex-col">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex flex-col flex-1 min-h-0">

          <div class="grid grid-cols-[1fr_auto_1fr] gap-6 mb-4 flex-1 min-h-0">

            <%# Lista disponibles global %>
            <div class="flex flex-col min-h-0">
              <div class="flex items-center gap-3 px-4 py-3 rounded-t-lg text-white"
                   style="background: linear-gradient(135deg, #4db8e8 0%, #0082c0 100%)">
                <span class="material-icons text-xl">security</span>
                <h3 class="flex-1 text-sm font-medium m-0">Permisos Disponibles</h3>
                <span data-permissions-target="unassignedCountGlobal"
                      class="bg-white/30 px-3 py-0.5 rounded-full text-xs font-bold">0</span>
                <button data-action="click->permissions#assignAllGlobal"
                        data-permissions-target="btnAssignAllGlobal"
                        data-testid="btn-assign-all-global"
                        class="text-white hover:bg-white/20 rounded p-0.5 transition-colors disabled:opacity-50"
                        title="Asignar todos">
                  <span class="material-icons">chevron_right</span>
                </button>
              </div>
              <div data-permissions-target="unassignedListGlobal"
                   data-testid="unassigned-list-global"
                   data-drop-zone="unassigned-global"
                   data-action="dragover->permissions#onDragOverGlobal drop->permissions#onDropGlobal"
                   class="flex-1 min-h-0 border-2 border-dashed border-gray-200 border-t-0 rounded-b-lg p-3 bg-gray-50 overflow-y-auto transition-colors">
                <div data-permissions-target="emptyUnassignedGlobal"
                     class="flex flex-col items-center justify-center h-full text-gray-400 py-10">
                  <span class="material-icons text-5xl opacity-40 mb-3">check_circle</span>
                  <p class="text-xs">Todos los permisos están asignados</p>
                </div>
              </div>
            </div>

            <%# Indicador central %>
            <div class="flex flex-col items-center justify-center gap-2 py-5">
              <span class="material-icons text-5xl text-gray-300 animate-pulse">swap_horiz</span>
              <p class="text-xs text-gray-400 text-center max-w-20">Arrastra para asignar/desasignar</p>
            </div>

            <%# Lista asignados global %>
            <div class="flex flex-col min-h-0">
              <div class="flex items-center gap-3 px-4 py-3 rounded-t-lg text-white"
                   style="background: linear-gradient(135deg, #0082c0 0%, #005a85 100%)">
                <button data-action="click->permissions#unassignAllGlobal"
                        data-permissions-target="btnUnassignAllGlobal"
                        data-testid="btn-unassign-all-global"
                        class="text-white hover:bg-white/20 rounded p-0.5 transition-colors disabled:opacity-50"
                        title="Desasignar todos">
                  <span class="material-icons">chevron_left</span>
                </button>
                <span class="material-icons text-xl">verified_user</span>
                <h3 class="flex-1 text-sm font-medium m-0">Permisos Asignados</h3>
                <span data-permissions-target="assignedCountGlobal"
                      class="bg-white/30 px-3 py-0.5 rounded-full text-xs font-bold">0</span>
              </div>
              <div data-permissions-target="assignedListGlobal"
                   data-testid="assigned-list-global"
                   data-drop-zone="assigned-global"
                   data-action="dragover->permissions#onDragOverGlobal drop->permissions#onDropGlobal"
                   class="flex-1 min-h-0 border-2 border-dashed border-gray-200 border-t-0 rounded-b-lg p-3 bg-gray-50 overflow-y-auto transition-colors">
                <div data-permissions-target="emptyAssignedGlobal"
                     class="flex flex-col items-center justify-center h-full text-gray-400 py-10">
                  <span class="material-icons text-5xl opacity-40 mb-3">inbox</span>
                  <p class="text-xs">No hay permisos asignados</p>
                </div>
              </div>
            </div>
          </div>

          <%# Resumen de cambios global %>
          <div data-permissions-target="changesSummaryGlobal"
               data-testid="changes-summary-global"
               class="hidden border-t border-gray-100 pt-4 mb-4">
            <div class="flex flex-col gap-3">
              <div data-permissions-target="assignSummaryRowGlobal"
                   class="hidden items-center gap-3 text-sm">
                <span class="material-icons text-green-500 text-xl">add_circle</span>
                <span><strong data-permissions-target="assignCountGlobal">0</strong> permiso(s) para asignar</span>
              </div>
              <div data-permissions-target="unassignSummaryRowGlobal"
                   class="hidden items-center gap-3 text-sm">
                <span class="material-icons text-red-500 text-xl">remove_circle</span>
                <span><strong data-permissions-target="unassignCountGlobal">0</strong> permiso(s) para desasignar</span>
              </div>
            </div>
          </div>

          <%# Botones acción global %>
          <div class="flex justify-end gap-3 pt-4 border-t border-gray-100">
            <button data-action="click->permissions#cancelChangesGlobal"
                    data-permissions-target="btnCancelGlobal"
                    data-testid="btn-cancel-global"
                    disabled
                    class="flex items-center gap-2 px-5 py-2 rounded-lg border border-red-300 text-red-600 text-sm font-medium hover:bg-red-50 transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
              <span class="material-icons text-base">close</span>
              Cancelar Cambios
            </button>
            <button data-action="click->permissions#applyChangesGlobal"
                    data-permissions-target="btnApply"
                    data-testid="btn-apply"
                    disabled
                    class="flex items-center gap-2 px-5 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
              <span class="material-icons text-base">check</span>
              Aplicar Cambios
            </button>
          </div>
        </div>
      </div>

      <%# Empty state sin usuario %>
      <div data-permissions-target="emptyUserState"
           data-testid="empty-user-state"
           class="bg-white rounded-xl shadow-sm border border-gray-100 p-16 text-center text-gray-400">
        <span class="material-icons text-9xl opacity-30 mb-5 block">person_search</span>
        <h2 class="text-2xl font-light mb-3">Selecciona un usuario</h2>
        <p class="text-base">Elige un usuario de la lista para gestionar sus permisos globales</p>
      </div>
    </div>

  </div><%# /flex-1 overflow-auto %>

  <%# ---------------------------------------------------------------- %>
  <%# MODAL DE ERROR %>
  <%# ---------------------------------------------------------------- %>
  <div data-permissions-target="errorModal"
       data-testid="error-modal"
       class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40">
    <div class="bg-white rounded-xl shadow-xl p-6 max-w-sm w-full mx-4">
      <div class="flex items-center gap-3 mb-3">
        <span class="material-icons text-red-500 text-2xl flex-shrink-0">error</span>
        <h3 data-permissions-target="errorTitle"
            class="text-base font-semibold text-gray-800"></h3>
      </div>
      <p data-permissions-target="errorSubtitle"
         class="text-sm text-gray-600 mb-5 break-words"></p>
      <div class="flex justify-end">
        <button type="button"
                data-action="click->permissions#closeErrorModal"
                class="px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 transition-colors">
          Entendido
        </button>
      </div>
    </div>
  </div>

</div>
