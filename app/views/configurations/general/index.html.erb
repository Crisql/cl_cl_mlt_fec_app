<% content_for :title, "Configuraciones Generales — FEC" %>
<% content_for :page_title, "Configuraciones Generales" %>

<div data-controller="general-configs"
     data-testid="general-configs-page"
     class="p-6">

  <%# ---------------------------------------------------------------- %>
  <%# GRID: auto-fit — máx 3 columnas, mín 1 %>
  <%# auto-fit colapsa columnas vacías, por lo que 2 secciones = 2 cols,  %>
  <%# 3 = 3 cols, 4 = 3+1, etc. %>
  <%# ---------------------------------------------------------------- %>
  <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(min(100%, 30%), 1fr)); gap:1.5rem;">

  <%# ---------------------------------------------------------------- %>
  <%# SECCIÓN: Formato de Impresión por Defecto %>
  <%# ---------------------------------------------------------------- %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
    <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-4">
      Formato de Impresión
    </h2>

    <div class="flex flex-col md:flex-row gap-4 items-start md:items-end">

      <%# Campo readonly + botones inline %>
      <div class="flex-1">
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Formato de Impresión por Defecto
        </label>
        <div class="relative flex items-center gap-1">
          <input type="text"
                 data-general-configs-target="printFormatInput"
                 data-testid="input-print-format"
                 readonly
                 placeholder="Seleccione un archivo .rpt"
                 class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm bg-gray-50 text-gray-700 focus:outline-none cursor-default">

          <%# Botón Upload — visible según permiso %>
          <div data-general-configs-target="uploadWrapper"
               class="hidden relative group inline-block shrink-0">
            <button type="button"
                    data-action="click->general-configs#triggerFileInput"
                    data-testid="btn-upload"
                    class="p-1.5 text-blue-600 rounded hover:bg-blue-50 transition-colors cursor-pointer">
              <span class="material-icons text-base">cloud_upload</span>
            </button>
            <span class="pointer-events-none absolute bottom-full left-1/2 -translate-x-1/2 mb-1
                         whitespace-nowrap rounded bg-gray-800 px-2 py-0.5 text-xs text-white
                         opacity-0 group-hover:opacity-100 transition-opacity z-10">
              Subir archivo .rpt
            </span>
          </div>

          <%# Botón Download — visible según permiso %>
          <div data-general-configs-target="downloadWrapper"
               class="hidden relative group inline-block shrink-0">
            <button type="button"
                    data-action="click->general-configs#downloadPrintFormat"
                    data-testid="btn-download"
                    class="p-1.5 text-blue-600 rounded hover:bg-blue-50 transition-colors cursor-pointer">
              <span class="material-icons text-base">download</span>
            </button>
            <span class="pointer-events-none absolute bottom-full left-1/2 -translate-x-1/2 mb-1
                         whitespace-nowrap rounded bg-gray-800 px-2 py-0.5 text-xs text-white
                         opacity-0 group-hover:opacity-100 transition-opacity z-10">
              Descargar formato
            </span>
          </div>
        </div>

        <%# Input file oculto %>
        <input type="file"
               data-general-configs-target="fileInput"
               data-testid="file-input"
               data-action="change->general-configs#onFileSelected"
               accept=".rpt"
               class="hidden">

        <p data-general-configs-target="printFormatError"
           class="hidden mt-1 text-xs text-red-500">
          Seleccione un archivo .rpt válido.
        </p>
      </div>

      <%# Botón Actualizar formato — visible según permiso %>
      <div data-general-configs-target="updateFormatWrapper" class="hidden shrink-0">
        <button type="button"
                data-action="click->general-configs#updatePrintFormat"
                data-general-configs-target="btnUpdateFormat"
                data-testid="btn-update-format"
                disabled
                class="flex items-center gap-2 px-5 py-2 rounded-lg bg-blue-600 text-white text-sm
                       font-medium hover:bg-blue-700 transition-colors
                       disabled:opacity-40 disabled:cursor-not-allowed">
          <span class="material-icons text-base">loop</span>
          <span>Actualizar</span>
        </button>
      </div>

    </div>
  </div>

  <%# ---------------------------------------------------------------- %>
  <%# SECCIÓN: Cédula Proveedor Sistemas %>
  <%# ---------------------------------------------------------------- %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
    <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-4">
      Configuración de Proveedor
    </h2>

    <div class="flex flex-col md:flex-row gap-4 items-start md:items-end">

      <div class="flex-1">
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Cédula Proveedor Sistemas
        </label>
        <input type="text"
               data-general-configs-target="cedulaInput"
               data-testid="input-cedula"
               placeholder="Ej: 3-101-123456"
               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                      focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
      </div>

      <div class="shrink-0">
        <button type="button"
                data-action="click->general-configs#updateCedula"
                data-testid="btn-update-cedula"
                class="flex items-center gap-2 px-5 py-2 rounded-lg bg-blue-600 text-white text-sm
                       font-medium hover:bg-blue-700 transition-colors">
          <span class="material-icons text-base">loop</span>
          <span>Actualizar</span>
        </button>
      </div>

    </div>
  </div>

  </div><%# /grid auto-fit %>

</div>
