<% content_for :title, "Configuraciones Generales" %>
<% content_for :page_title, "Generales" %>

<div data-controller="general-configs"
     data-testid="general-configs-page"
     class="p-6">

  <%# ---------------------------------------------------------------- %>
  <%# GRID: 2 columnas fijas. El card Crystal span 2 cols (fila propia). %>
  <%# ---------------------------------------------------------------- %>
  <div style="display:grid; grid-template-columns:repeat(2, 1fr); gap:1.5rem;">

  <%# ---------------------------------------------------------------- %>
  <%# SECCIÓN: Formato de Impresión por Defecto %>
  <%# ---------------------------------------------------------------- %>
  <div class="relative bg-white rounded-xl shadow-sm border border-gray-100 p-6">

    <%# Loader a nivel de sección (sin texto) %>
    <div data-general-configs-target="formatLoader"
         class="hidden absolute inset-0 z-30 flex items-center justify-center bg-white/60 rounded-xl">
      <svg width="40" height="40" viewBox="0 0 50 50" aria-hidden="true">
        <circle cx="25" cy="25" r="20" fill="none" stroke="#e5e7eb" stroke-width="5"></circle>
        <circle cx="25" cy="25" r="20" fill="none" stroke="#2563eb" stroke-width="5"
                stroke-linecap="round" stroke-dasharray="80 200">
          <animateTransform attributeName="transform" attributeType="XML" type="rotate"
                            from="0 25 25" to="360 25 25" dur="0.8s" repeatCount="indefinite"></animateTransform>
        </circle>
      </svg>
    </div>

    <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-4">
      Formato de Impresión
    </h2>

    <div class="flex flex-col md:flex-row gap-4 items-start md:items-end">

      <%# Campo readonly + botones sufijo (patrón matSuffix — CLAUDE.md §4) %>
      <div class="flex-1">
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Formato de Impresión por Defecto
        </label>
        <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden
                    focus-within:ring-2 focus-within:ring-blue-500 bg-gray-50">
          <input type="text"
                 data-general-configs-target="printFormatInput"
                 data-testid="input-print-format"
                 readonly
                 placeholder="Seleccione un archivo .rpt"
                 class="flex-1 px-3 py-2 text-sm bg-transparent outline-none cursor-default">

          <%# Botón Upload — visible según permiso %>
          <button type="button"
                  data-general-configs-target="uploadWrapper"
                  data-action="click->general-configs#triggerFileInput"
                  data-testid="btn-upload"
                  title="Subir archivo .rpt"
                  class="hidden self-stretch flex items-center px-2 border-l border-gray-200
                         text-gray-500 hover:bg-gray-100 hover:text-gray-700 transition-colors flex-shrink-0">
            <span class="material-icons text-base leading-none">cloud_upload</span>
          </button>

          <%# Botón Download — visible según permiso %>
          <button type="button"
                  data-general-configs-target="downloadWrapper"
                  data-action="click->general-configs#downloadPrintFormat"
                  data-testid="btn-download"
                  title="Descargar formato"
                  class="hidden self-stretch flex items-center px-2 border-l border-gray-200
                         text-gray-500 hover:bg-gray-100 hover:text-gray-700 transition-colors flex-shrink-0">
            <span class="material-icons text-base leading-none">download</span>
          </button>
        </div>

        <%# Input file oculto %>
        <input type="file"
               data-general-configs-target="fileInput"
               data-testid="file-input"
               data-action="change->general-configs#onFileSelected"
               accept=".rpt"
               class="hidden">

        <p data-general-configs-target="printFormatError"
           class="hidden mt-1 text-xs text-red-500">
          Seleccione un archivo .rpt válido.
        </p>
      </div>

      <%# Botón Actualizar formato — visible según permiso %>
      <div data-general-configs-target="updateFormatWrapper" class="hidden shrink-0">
        <button type="button"
                data-action="click->general-configs#updatePrintFormat"
                data-general-configs-target="btnUpdateFormat"
                data-testid="btn-update-format"
                disabled
                class="flex items-center gap-2 px-5 py-2 rounded-lg bg-blue-600 text-white text-sm
                       font-medium hover:bg-blue-700 transition-colors
                       disabled:opacity-40 disabled:cursor-not-allowed">
          <span class="material-icons text-base">loop</span>
          <span>Actualizar</span>
        </button>
      </div>

    </div>

    <%# Metadato de auditoría — última actualización (CLAUDE.md §24) %>
    <div data-general-configs-target="formatAudit"
         class="hidden mt-3 pt-2.5 border-t border-gray-100 flex items-center gap-1.5 text-xs text-gray-400">
      <span class="material-icons text-sm leading-none">history</span>
      <span data-general-configs-target="formatAuditText"></span>
    </div>
  </div>

  <%# ---------------------------------------------------------------- %>
  <%# SECCIÓN: Cédula Proveedor Sistemas %>
  <%# ---------------------------------------------------------------- %>
  <div class="relative bg-white rounded-xl shadow-sm border border-gray-100 p-6">

    <%# Loader a nivel de sección (sin texto) %>
    <div data-general-configs-target="cedulaLoader"
         class="hidden absolute inset-0 z-30 flex items-center justify-center bg-white/60 rounded-xl">
      <svg width="40" height="40" viewBox="0 0 50 50" aria-hidden="true">
        <circle cx="25" cy="25" r="20" fill="none" stroke="#e5e7eb" stroke-width="5"></circle>
        <circle cx="25" cy="25" r="20" fill="none" stroke="#2563eb" stroke-width="5"
                stroke-linecap="round" stroke-dasharray="80 200">
          <animateTransform attributeName="transform" attributeType="XML" type="rotate"
                            from="0 25 25" to="360 25 25" dur="0.8s" repeatCount="indefinite"></animateTransform>
        </circle>
      </svg>
    </div>

    <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-4">
      Configuración de Proveedor
    </h2>

    <div class="flex flex-col md:flex-row gap-4 items-start md:items-end">

      <div class="flex-1">
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Cédula Proveedor Sistemas
        </label>
        <input type="text"
               data-general-configs-target="cedulaInput"
               data-action="input->general-configs#onCedulaInput"
               data-testid="input-cedula"
               placeholder="Ej: 3-101-123456"
               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                      focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
      </div>

      <div class="shrink-0">
        <button type="button"
                data-action="click->general-configs#updateCedula"
                data-general-configs-target="btnUpdateCedula"
                data-testid="btn-update-cedula"
                disabled
                class="flex items-center gap-2 px-5 py-2 rounded-lg bg-blue-600 text-white text-sm
                       font-medium hover:bg-blue-700 transition-colors
                       disabled:opacity-40 disabled:cursor-not-allowed">
          <span class="material-icons text-base">loop</span>
          <span>Actualizar</span>
        </button>
      </div>

    </div>

    <%# Metadato de auditoría — última actualización (CLAUDE.md §24) %>
    <div data-general-configs-target="cedulaAudit"
         class="hidden mt-3 pt-2.5 border-t border-gray-100 flex items-center gap-1.5 text-xs text-gray-400">
      <span class="material-icons text-sm leading-none">history</span>
      <span data-general-configs-target="cedulaAuditText"></span>
    </div>
  </div>

  <%# ---------------------------------------------------------------- %>
  <%# SECCIÓN: Credenciales Crystal — span 2 cols %>
  <%# ---------------------------------------------------------------- %>
  <div class="relative bg-white rounded-xl shadow-sm border border-gray-100 p-6">

    <%# Loader a nivel de sección (sin texto) %>
    <div data-general-configs-target="crystalLoader"
         class="hidden absolute inset-0 z-30 flex items-center justify-center bg-white/60 rounded-xl">
      <svg width="40" height="40" viewBox="0 0 50 50" aria-hidden="true">
        <circle cx="25" cy="25" r="20" fill="none" stroke="#e5e7eb" stroke-width="5"></circle>
        <circle cx="25" cy="25" r="20" fill="none" stroke="#2563eb" stroke-width="5"
                stroke-linecap="round" stroke-dasharray="80 200">
          <animateTransform attributeName="transform" attributeType="XML" type="rotate"
                            from="0 25 25" to="360 25 25" dur="0.8s" repeatCount="indefinite"></animateTransform>
        </circle>
      </svg>
    </div>

    <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-4">
      Credenciales Crystal
    </h2>

    <div class="mb-4 flex items-start gap-2 rounded-lg bg-blue-50 border border-blue-100 px-3 py-2.5">
      <span class="material-icons text-sm text-blue-500 flex-shrink-0 mt-px">info</span>
      <p class="text-xs text-blue-700">
        Esta sección está en proceso de integración. Por ahora la aplicación lee las credenciales
        de Crystal Reports desde su configuración interna (<code class="font-mono">appsettings.json</code>).
      </p>
    </div>

    <div class="flex flex-col md:flex-row gap-4 items-start md:items-end">

      <div class="flex-1">
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Usuario
        </label>
        <input type="text"
               data-general-configs-target="crystalUserInput"
               data-action="input->general-configs#onCrystalInput"
               data-testid="input-crystal-user"
               placeholder="Usuario de Crystal Reports"
               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                      focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
      </div>

      <div class="flex-1">
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Contraseña
        </label>
        <div class="relative">
          <input type="password"
                 data-general-configs-target="crystalPasswordInput"
                 data-action="input->general-configs#onCrystalInput"
                 data-testid="input-crystal-password"
                 placeholder="Contraseña de Crystal Reports"
                 class="w-full border border-gray-300 rounded-lg px-3 py-2 pr-10 text-sm
                        focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
          <button type="button"
                  data-action="click->general-configs#toggleCrystalPassword"
                  data-general-configs-target="crystalPasswordToggle"
                  title="Mostrar/ocultar contraseña"
                  class="absolute right-2 top-1/2 -translate-y-1/2 p-1 text-gray-500 hover:text-gray-700 transition-colors">
            <span class="material-icons text-base">visibility_off</span>
          </button>
        </div>
      </div>

      <div class="shrink-0">
        <button type="button"
                data-action="click->general-configs#updateCrystal"
                data-general-configs-target="btnUpdateCrystal"
                data-testid="btn-update-crystal"
                disabled
                class="flex items-center gap-2 px-5 py-2 rounded-lg bg-blue-600 text-white text-sm
                       font-medium hover:bg-blue-700 transition-colors
                       disabled:opacity-40 disabled:cursor-not-allowed">
          <span class="material-icons text-base">loop</span>
          <span>Actualizar</span>
        </button>
      </div>

    </div>

    <%# Metadato de auditoría — última actualización (CLAUDE.md §24) %>
    <div data-general-configs-target="crystalAudit"
         class="hidden mt-3 pt-2.5 border-t border-gray-100 flex items-center gap-1.5 text-xs text-gray-400">
      <span class="material-icons text-sm leading-none">history</span>
      <span data-general-configs-target="crystalAuditText"></span>
    </div>
  </div>

  </div><%# /grid auto-fit %>


</div>
