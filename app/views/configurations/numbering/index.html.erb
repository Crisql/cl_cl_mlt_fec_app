<% content_for :title, "Numeración" %>
<% content_for :page_title, "Numeración" %>

<div data-controller="numbering"
     data-testid="numbering-page"
     class="p-6 flex flex-col gap-4 h-full relative">

  <%# ================================================================ %>
  <%# TABS %>
  <%# ================================================================ %>
  <div class="flex-shrink-0 border-b border-gray-200">
    <nav class="flex gap-1" aria-label="Tabs">
      <button type="button"
              data-action="click->numbering#switchTab"
              data-tab="numbering"
              data-numbering-target="tabNumbering"
              data-testid="tab-numbering"
              class="px-4 py-2 text-sm font-medium rounded-t-lg border-b-2 border-blue-600 text-blue-600 bg-white transition-colors">
        Numeraciones de Emisión
      </button>
      <button type="button"
              data-action="click->numbering#switchTab"
              data-tab="reception"
              data-numbering-target="tabReception"
              data-testid="tab-reception"
              class="px-4 py-2 text-sm font-medium rounded-t-lg border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 transition-colors">
        Numeraciones de Recepción
      </button>
    </nav>
  </div>

  <%# ================================================================ %>
  <%# TAB 1: Numeraciones de Emisión %>
  <%# ================================================================ %>
  <div data-numbering-target="numberingPanelTab"
       data-testid="panel-numbering"
       class="flex flex-col flex-1 min-h-0 gap-4 relative">

    <%# Loader de la sección Numeración — cubre filtros y tabla %>
    <div data-numbering-target="numberingLoader"
         class="hidden absolute inset-0 z-30 flex items-center justify-center bg-white/60 rounded-lg">
      <svg width="40" height="40" viewBox="0 0 50 50" aria-hidden="true">
        <circle cx="25" cy="25" r="20" fill="none" stroke="#e5e7eb" stroke-width="5"></circle>
        <circle cx="25" cy="25" r="20" fill="none" stroke="#2563eb" stroke-width="5"
                stroke-linecap="round" stroke-dasharray="80 200">
          <animateTransform attributeName="transform" attributeType="XML" type="rotate"
                            from="0 25 25" to="360 25 25" dur="0.8s" repeatCount="indefinite"></animateTransform>
        </circle>
      </svg>
    </div>

    <%# Filtros de búsqueda %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 flex-shrink-0">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-6 gap-3 items-end">

        <div class="flex flex-col gap-1">
          <label class="text-xs font-medium text-gray-500 uppercase tracking-wide">Tipo de documento</label>
          <select data-numbering-target="numFilterDocType"
                  data-testid="num-filter-doc-type"
                  class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
            <option value="">Todos</option>
            <option value="01">Factura electrónica</option>
            <option value="02">Nota de débito electrónica</option>
            <option value="03">Nota de crédito electrónica</option>
            <option value="04">Tiquete electrónico</option>
            <option value="08">Factura electrónica de compra</option>
            <option value="09">Factura electrónica de exportación</option>
            <option value="10">Recibo electrónico de pago</option>
          </select>
        </div>

        <div class="flex flex-col gap-1">
          <label class="text-xs font-medium text-gray-500 uppercase tracking-wide">Sucursal</label>
          <select data-numbering-target="numFilterSucursal"
                  data-testid="num-filter-sucursal"
                  class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
            <option value="">Todas</option>
          </select>
        </div>

        <div class="flex flex-col gap-1">
          <label class="text-xs font-medium text-gray-500 uppercase tracking-wide">Terminal</label>
          <input type="text"
                 inputmode="numeric"
                 data-numbering-target="numFilterTerminal"
                 data-testid="num-filter-terminal"
                 placeholder="Terminal"
                 class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>

        <div class="flex flex-col gap-1">
          <label class="text-xs font-medium text-gray-500 uppercase tracking-wide">Estado</label>
          <select data-numbering-target="numFilterEstado"
                  data-testid="num-filter-estado"
                  class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
            <option value="">Todos</option>
            <option value="1">Activo</option>
            <option value="0">Inactivo</option>
          </select>
        </div>

        <div class="flex gap-2 lg:col-span-2">
          <button type="button"
                  data-action="click->numbering#filterNumbering"
                  data-testid="num-btn-search"
                  class="flex-1 inline-flex items-center justify-center gap-1 px-4 py-2 border border-blue-600 text-blue-600 text-sm font-medium rounded-lg hover:bg-blue-50 transition-colors whitespace-nowrap">
            <span class="material-icons text-base">filter_alt</span>
            Consultar
          </button>
          <span data-numbering-target="btnCreateNumberingWrap"
                data-tooltip="No cuenta con permisos para crear numeraciones de emisión"
                class="flex-1">
            <button type="button"
                    data-action="click->numbering#openCreateNumbering"
                    data-numbering-target="btnCreateNumbering"
                    data-testid="btn-new-numbering"
                    disabled
                    class="w-full inline-flex items-center justify-center gap-1 px-4 py-2 bg-gray-300 text-gray-500 text-sm font-medium rounded-lg cursor-not-allowed pointer-events-none transition-colors whitespace-nowrap">
              <span class="material-icons text-base">add</span>
              Nueva Numeración de Emisión
            </button>
          </span>
        </div>
      </div>
    </div>

    <%# Tabla %>
    <div class="flex-1 min-h-0 bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div data-numbering-target="numberingTable"
           data-testid="numbering-table"
           class="h-full">
      </div>
    </div>
  </div>

  <%# ================================================================ %>
  <%# TAB 2: Numeración de Recepción %>
  <%# ================================================================ %>
  <div data-numbering-target="receptionPanelTab"
       data-testid="panel-reception"
       class="hidden flex flex-col flex-1 min-h-0 gap-4 relative">

    <%# Loader de la sección Numeración de Recepción — cubre filtros y tabla %>
    <div data-numbering-target="receptionLoader"
         class="hidden absolute inset-0 z-30 flex items-center justify-center bg-white/60 rounded-lg">
      <svg width="40" height="40" viewBox="0 0 50 50" aria-hidden="true">
        <circle cx="25" cy="25" r="20" fill="none" stroke="#e5e7eb" stroke-width="5"></circle>
        <circle cx="25" cy="25" r="20" fill="none" stroke="#2563eb" stroke-width="5"
                stroke-linecap="round" stroke-dasharray="80 200">
          <animateTransform attributeName="transform" attributeType="XML" type="rotate"
                            from="0 25 25" to="360 25 25" dur="0.8s" repeatCount="indefinite"></animateTransform>
        </circle>
      </svg>
    </div>

    <%# Filtros de búsqueda %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 flex-shrink-0">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 items-end">

        <div class="flex flex-col gap-1">
          <label class="text-xs font-medium text-gray-500 uppercase tracking-wide">Sucursal</label>
          <select data-numbering-target="recFilterSucursal"
                  data-testid="rec-filter-sucursal"
                  class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
            <option value="">Todas</option>
          </select>
        </div>

        <div class="flex flex-col gap-1">
          <label class="text-xs font-medium text-gray-500 uppercase tracking-wide">Terminal</label>
          <input type="text"
                 inputmode="numeric"
                 data-numbering-target="recFilterTerminal"
                 data-testid="rec-filter-terminal"
                 placeholder="Terminal"
                 class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>

        <div class="flex flex-col gap-1">
          <label class="text-xs font-medium text-gray-500 uppercase tracking-wide">Estado</label>
          <select data-numbering-target="recFilterEstado"
                  data-testid="rec-filter-estado"
                  class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
            <option value="">Todos</option>
            <option value="1">Activo</option>
            <option value="0">Inactivo</option>
          </select>
        </div>

        <div class="flex gap-2">
          <button type="button"
                  data-action="click->numbering#filterReception"
                  data-testid="rec-btn-search"
                  class="flex-1 inline-flex items-center justify-center gap-1 px-4 py-2 border border-blue-600 text-blue-600 text-sm font-medium rounded-lg hover:bg-blue-50 transition-colors">
            <span class="material-icons text-base">filter_alt</span>
            Consultar
          </button>
          <span data-numbering-target="btnCreateReceptionWrap"
                data-tooltip="No cuenta con permisos para crear numeraciones de recepción"
                class="flex-1">
            <button type="button"
                    data-action="click->numbering#openCreateReception"
                    data-numbering-target="btnCreateReception"
                    data-testid="btn-new-reception"
                    disabled
                    class="w-full inline-flex items-center justify-center gap-1 px-4 py-2 bg-gray-300 text-gray-500 text-sm font-medium rounded-lg cursor-not-allowed pointer-events-none transition-colors">
              <span class="material-icons text-base">add</span>
              Nueva Numeración de Recepción
            </button>
          </span>
        </div>
      </div>
    </div>

    <%# Tabla %>
    <div class="flex-1 min-h-0 bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div data-numbering-target="receptionTable"
           data-testid="reception-table"
           class="h-full">
      </div>
    </div>
  </div>

  <%# ================================================================ %>
  <%# PANEL LATERAL — Numeración %>
  <%# ================================================================ %>

  <%# Backdrop %>
  <div data-numbering-target="numberingPanelBackdrop"
       data-action="click->numbering#closeNumberingPanel"
       class="hidden fixed inset-0 z-40 bg-black/40">
  </div>

  <%# Panel %>
  <div data-numbering-target="numberingPanel"
       class="fixed top-0 right-0 h-full w-full max-w-lg bg-white shadow-2xl z-50
              translate-x-full transition-transform duration-300 ease-in-out flex flex-col">

    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100 flex-shrink-0">
      <h3 class="text-base font-semibold text-gray-800"
          data-numbering-target="numberingPanelTitle">Numeración</h3>
      <button type="button"
              data-action="click->numbering#closeNumberingPanel"
              class="p-1 text-gray-400 hover:text-gray-600 rounded hover:bg-gray-100 transition-colors">
        <span class="material-icons text-xl">close</span>
      </button>
    </div>

    <div class="flex-1 overflow-y-auto px-6 py-5 flex flex-col gap-4">

      <%# Número Siguiente %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Número Siguiente <span class="text-red-500">*</span>
        </label>
        <input type="number"
               min="1"
               data-numbering-target="numNextNumber"
               data-testid="input-next-number"
               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
               placeholder="Número Siguiente">
        <p class="hidden mt-1 text-xs text-red-600" data-numbering-target="numNextNumberError">
          El número siguiente es requerido.
        </p>
      </div>

      <%# Tipo de Documento %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Tipo de Documento <span class="text-red-500">*</span>
        </label>
        <select data-numbering-target="numDocType"
                data-testid="select-doc-type"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
          <option value="">-- Seleccione --</option>
          <option value="01">Factura electrónica</option>
          <option value="02">Nota de débito electrónica</option>
          <option value="03">Nota de crédito electrónica</option>
          <option value="04">Tiquete electrónico</option>
          <option value="08">Factura electrónica de compra</option>
          <option value="09">Factura electrónica de exportación</option>
          <option value="10">Recibo electrónico de pago</option>
        </select>
        <p class="hidden mt-1 text-xs text-red-600" data-numbering-target="numDocTypeError">
          El tipo de documento es requerido.
        </p>
      </div>

      <%# Sucursal %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Sucursal <span class="text-red-500">*</span>
        </label>
        <select data-numbering-target="numSucursal"
                data-testid="select-sucursal"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
          <option value="">-- Seleccione --</option>
        </select>
        <p class="hidden mt-1 text-xs text-red-600" data-numbering-target="numSucursalError">
          La sucursal es requerida.
        </p>
      </div>

      <%# Terminal %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Terminal <span class="text-red-500">*</span>
        </label>
        <input type="number"
               min="0"
               data-numbering-target="numTerminal"
               data-testid="input-terminal"
               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
               placeholder="Terminal">
        <p class="hidden mt-1 text-xs text-red-600" data-numbering-target="numTerminalError">
          La terminal es requerida y no puede ser negativa.
        </p>
      </div>

      <%# Observaciones %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Observaciones <span class="text-red-500">*</span>
        </label>
        <input type="text"
               data-numbering-target="numObvs"
               data-testid="input-obvs"
               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
               placeholder="Observaciones">
        <p class="hidden mt-1 text-xs text-red-600" data-numbering-target="numObvsError">
          Las observaciones son requeridas.
        </p>
      </div>

      <%# Tipo de Integración %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Tipo de Integración <span class="text-red-500">*</span>
        </label>
        <select data-numbering-target="numIntegration"
                data-testid="select-integration"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
          <option value="">-- Seleccione --</option>
          <option value="1">Integrador</option>
          <option value="2">AppFE</option>
        </select>
        <p class="hidden mt-1 text-xs text-red-600" data-numbering-target="numIntegrationError">
          El tipo de integración es requerido.
        </p>
      </div>

      <%# Estado %>
      <div class="flex items-center gap-3">
        <label class="text-sm font-medium text-gray-700">Estado</label>
        <label class="relative inline-flex items-center cursor-pointer">
          <input type="checkbox"
                 data-numbering-target="numActive"
                 data-testid="check-active"
                 checked
                 class="sr-only peer">
          <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-blue-500
                      rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white
                      after:content-[''] after:absolute after:top-[2px] after:left-[2px]
                      after:bg-white after:border-gray-300 after:border after:rounded-full
                      after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
          <span class="ml-2 text-sm text-gray-600" data-numbering-target="numActiveLabel">Activo</span>
        </label>
      </div>

    </div>

    <div class="px-6 py-4 border-t border-gray-100 flex justify-end gap-3 flex-shrink-0">
      <button type="button"
              data-action="click->numbering#closeNumberingPanel"
              class="inline-flex items-center gap-1 px-4 py-2 border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 transition-colors">
        <span class="material-icons text-base">cancel</span>
        Cancelar
      </button>
      <button type="button"
              data-action="click->numbering#saveNumbering"
              data-numbering-target="numSaveBtn"
              data-testid="btn-save-numbering"
              class="inline-flex items-center gap-1 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
        <span class="material-icons text-base" data-numbering-target="numSaveIcon">check</span>
        <span data-numbering-target="numSaveLabel">Crear</span>
      </button>
    </div>
  </div>

  <%# ================================================================ %>
  <%# PANEL LATERAL — Numeración de Recepción %>
  <%# ================================================================ %>

  <%# Backdrop %>
  <div data-numbering-target="receptionPanelBackdrop"
       data-action="click->numbering#closeReceptionPanel"
       class="hidden fixed inset-0 z-40 bg-black/40">
  </div>

  <%# Panel %>
  <div data-numbering-target="receptionPanel"
       class="fixed top-0 right-0 h-full w-full max-w-lg bg-white shadow-2xl z-50
              translate-x-full transition-transform duration-300 ease-in-out flex flex-col">

    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100 flex-shrink-0">
      <h3 class="text-base font-semibold text-gray-800"
          data-numbering-target="receptionPanelTitle">Numeración de Recepción</h3>
      <button type="button"
              data-action="click->numbering#closeReceptionPanel"
              class="p-1 text-gray-400 hover:text-gray-600 rounded hover:bg-gray-100 transition-colors">
        <span class="material-icons text-xl">close</span>
      </button>
    </div>

    <div class="flex-1 overflow-y-auto px-6 py-5 flex flex-col gap-4">

      <%# Número Siguiente — solo editable en modo edición %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Número Siguiente <span class="text-red-500">*</span>
        </label>
        <input type="number"
               min="1"
               data-numbering-target="recNextNumber"
               data-testid="input-rec-next-number"
               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
               placeholder="Número Siguiente">
        <p class="hidden mt-1 text-xs text-red-600" data-numbering-target="recNextNumberError">
          El número siguiente es requerido.
        </p>
      </div>

      <%# Sucursal %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Sucursal <span class="text-red-500">*</span>
        </label>
        <select data-numbering-target="recSucursal"
                data-testid="select-rec-sucursal"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
          <option value="">-- Seleccione --</option>
        </select>
        <p class="hidden mt-1 text-xs text-red-600" data-numbering-target="recSucursalError">
          La sucursal es requerida.
        </p>
      </div>

      <%# Terminal %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Terminal <span class="text-red-500">*</span>
        </label>
        <input type="number"
               min="0"
               data-numbering-target="recTerminal"
               data-testid="input-rec-terminal"
               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
               placeholder="Terminal">
        <p class="hidden mt-1 text-xs text-red-600" data-numbering-target="recTerminalError">
          La terminal es requerida.
        </p>
      </div>

      <%# Observaciones %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Observaciones <span class="text-red-500">*</span>
        </label>
        <input type="text"
               data-numbering-target="recObvs"
               data-testid="input-rec-obvs"
               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
               placeholder="Observaciones">
        <p class="hidden mt-1 text-xs text-red-600" data-numbering-target="recObvsError">
          Las observaciones son requeridas.
        </p>
      </div>

      <%# Tipo de Integración %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Tipo de Integración <span class="text-red-500">*</span>
        </label>
        <select data-numbering-target="recIntegration"
                data-testid="select-rec-integration"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
          <option value="">-- Seleccione --</option>
          <option value="1">Integrador</option>
          <option value="2">AppFE</option>
        </select>
        <p class="hidden mt-1 text-xs text-red-600" data-numbering-target="recIntegrationError">
          El tipo de integración es requerido.
        </p>
      </div>

      <%# Estado %>
      <div class="flex items-center gap-3">
        <label class="text-sm font-medium text-gray-700">Estado</label>
        <label class="relative inline-flex items-center cursor-pointer">
          <input type="checkbox"
                 data-numbering-target="recActive"
                 data-testid="check-rec-active"
                 checked
                 class="sr-only peer">
          <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-blue-500
                      rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white
                      after:content-[''] after:absolute after:top-[2px] after:left-[2px]
                      after:bg-white after:border-gray-300 after:border after:rounded-full
                      after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
          <span class="ml-2 text-sm text-gray-600" data-numbering-target="recActiveLabel">Activo</span>
        </label>
      </div>

    </div>

    <div class="px-6 py-4 border-t border-gray-100 flex justify-end gap-3 flex-shrink-0">
      <button type="button"
              data-action="click->numbering#closeReceptionPanel"
              class="inline-flex items-center gap-1 px-4 py-2 border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 transition-colors">
        <span class="material-icons text-base">cancel</span>
        Cancelar
      </button>
      <button type="button"
              data-action="click->numbering#saveReception"
              data-numbering-target="recSaveBtn"
              data-testid="btn-save-reception"
              class="inline-flex items-center gap-1 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
        <span class="material-icons text-base" data-numbering-target="recSaveIcon">check</span>
        <span data-numbering-target="recSaveLabel">Crear</span>
      </button>
    </div>
  </div>


</div>
