<% content_for :title, "Registrar Usuario" %>
<% content_for :page_title, "Registrar Usuario" %>

<%# Register User — migración de /configurations/users/register %>
<div data-controller="users-register"
     class="p-6 flex flex-col h-full">

  <%= render 'shared/overlay_loader',
        ctrl:    'users-register',
        message: 'Registrando usuario...' %>

  <div class="flex-1 min-h-0 overflow-y-auto">
    <div class="max-w-3xl mx-auto">

      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h2 class="text-base font-semibold text-gray-800 mb-6">Información del nuevo usuario</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

          <%# Compañía %>
          <div class="flex flex-col gap-1">
            <label class="text-sm font-medium text-gray-700">
              Compañía <span class="text-red-500">*</span>
            </label>
            <select data-users-register-target="companySelect"
                    data-action="change->users-register#onCompanyChange"
                    class="border border-gray-300 rounded-lg px-3 py-2 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-blue-500">
              <option value="">Cargando...</option>
            </select>
          </div>

          <%# Cuenta (Grupo) %>
          <div class="flex flex-col gap-1">
            <label class="text-sm font-medium text-gray-700">
              Cuenta <span class="text-red-500">*</span>
            </label>
            <select data-users-register-target="groupSelect"
                    class="border border-gray-300 rounded-lg px-3 py-2 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-blue-500">
              <option value="">Cargando...</option>
            </select>
          </div>

          <%# Nombre Completo %>
          <div class="flex flex-col gap-1">
            <label class="text-sm font-medium text-gray-700">
              Nombre Completo <span class="text-red-500">*</span>
            </label>
            <input type="text"
                   data-users-register-target="fullName"
                   placeholder="Nombre Completo"
                   class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            <span data-users-register-target="fullNameError"
                  class="hidden text-xs text-red-500">El nombre completo es requerido.</span>
          </div>

          <%# Identificación %>
          <div class="flex flex-col gap-1">
            <label class="text-sm font-medium text-gray-700">
              Cédula <span class="text-red-500">*</span>
            </label>
            <input type="text"
                   data-users-register-target="identification"
                   placeholder="Identificación"
                   inputmode="numeric"
                   class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            <span data-users-register-target="identificationError"
                  class="hidden text-xs text-red-500">La identificación es requerida.</span>
          </div>

          <%# Email / Usuario %>
          <div class="flex flex-col gap-1">
            <label class="text-sm font-medium text-gray-700">
              Usuario (correo) <span class="text-red-500">*</span>
            </label>
            <input type="text"
                   data-users-register-target="email"
                   placeholder="usuario@empresa.com"
                   class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            <span data-users-register-target="emailError"
                  class="hidden text-xs text-red-500">Ingrese un correo válido.</span>
          </div>

          <%# Tipo de OC (solo para compañías con OC) %>
          <div data-users-register-target="ocTypeWrapper"
               class="flex flex-col gap-1">
            <label class="text-sm font-medium text-gray-700">
              Tipo de OC <span class="text-red-500">*</span>
            </label>
            <select data-users-register-target="ocType"
                    class="border border-gray-300 rounded-lg px-3 py-2 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-blue-500">
              <option value="">-- Seleccione --</option>
              <option value="1">Con número de OC</option>
              <option value="2">Sin número de OC</option>
            </select>
            <span data-users-register-target="ocTypeError"
                  class="hidden text-xs text-red-500">El tipo de OC es requerido.</span>
          </div>

        </div>

        <%# Acciones %>
        <div class="flex justify-end gap-3 mt-6 pt-4 border-t border-gray-100">
          <a href="<%= configurations_users_path %>"
             class="inline-flex items-center gap-1 px-4 py-2 border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 transition-colors">
            <span class="material-icons text-base">cancel</span>
            Cancelar
          </a>
          <button type="button"
                  data-users-register-target="submitBtn"
                  data-action="click->users-register#createUser"
                  disabled
                  class="inline-flex items-center gap-1 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
            <span class="material-icons text-base">check</span>
            Registrar
          </button>
        </div>

      </div>
    </div>
  </div>

</div>
