<% content_for :title, "Editar Usuario" %>
<% content_for :page_title, "Editar Usuario" %>

<%# Edit User — migración de /configurations/users/update?userId=... %>
<div data-controller="users-edit"
     class="p-6 flex flex-col h-full">

  <%= render 'shared/overlay_loader',
        ctrl:    'users-edit',
        message: 'Actualizando usuario...' %>

  <div class="flex-1 min-h-0 overflow-y-auto">
    <div class="max-w-3xl mx-auto">

      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h2 class="text-base font-semibold text-gray-800 mb-6">Información del usuario</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

          <%# Nombre Completo %>
          <div class="flex flex-col gap-1">
            <label class="text-sm font-medium text-gray-700">
              Nombre Completo <span class="text-red-500">*</span>
            </label>
            <input type="text"
                   data-users-edit-target="fullName"
                   placeholder="Nombre Completo"
                   class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            <span data-users-edit-target="fullNameError"
                  class="hidden text-xs text-red-500">El nombre completo es requerido.</span>
          </div>

          <%# Identificación %>
          <div class="flex flex-col gap-1">
            <label class="text-sm font-medium text-gray-700">
              Identificación <span class="text-red-500">*</span>
            </label>
            <input type="text"
                   data-users-edit-target="identification"
                   placeholder="Identificación"
                   inputmode="numeric"
                   class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            <span data-users-edit-target="identificationError"
                  class="hidden text-xs text-red-500">La identificación es requerida.</span>
          </div>

          <%# Usuario SAP %>
          <div class="flex flex-col gap-1">
            <label class="text-sm font-medium text-gray-700">
              Usuario de SAP <span class="text-red-500">*</span>
            </label>
            <input type="text"
                   data-users-edit-target="sapUser"
                   data-action="input->users-edit#onSapFieldChange"
                   placeholder="Usuario de SAP"
                   class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            <span data-users-edit-target="sapUserError"
                  class="hidden text-xs text-red-500">El usuario de SAP es requerido.</span>
          </div>

          <%# Contraseña SAP %>
          <div class="flex flex-col gap-1">
            <label class="text-sm font-medium text-gray-700">Contraseña de SAP</label>
            <div class="relative">
              <input type="password"
                     data-users-edit-target="sapPass"
                     data-action="input->users-edit#onSapFieldChange"
                     placeholder="Dejar vacío para no cambiar"
                     class="w-full border border-gray-300 rounded-lg px-3 py-2 pr-10 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
              <button type="button"
                      data-action="click->users-edit#togglePassVisibility"
                      class="absolute right-2 top-1/2 -translate-y-1/2 p-1 text-gray-500 hover:text-gray-700">
                <span data-users-edit-target="passIcon" class="material-icons text-base">visibility_off</span>
              </button>
            </div>
            <p class="text-xs text-gray-400">Dejar vacío si no desea cambiar la contraseña</p>
          </div>

          <%# Compañía para probar credenciales %>
          <div class="flex flex-col gap-1">
            <label class="text-sm font-medium text-gray-700">Compañía para probar credenciales</label>
            <select data-users-edit-target="credentialCompany"
                    data-action="change->users-edit#onCredentialCompanyChange"
                    class="border border-gray-300 rounded-lg px-3 py-2 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-blue-500">
              <option value="">-- Seleccione --</option>
            </select>
            <p class="text-xs text-gray-400">Se usará la conexión SAP de esta compañía.</p>
          </div>

          <%# Activo %>
          <div class="flex flex-col gap-1 justify-center">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox"
                     data-users-edit-target="activeCheck"
                     class="h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500">
              <span class="text-sm font-medium text-gray-700">Activo</span>
            </label>
          </div>

        </div>

        <%# Acciones %>
        <div class="flex flex-wrap justify-end gap-3 mt-6 pt-4 border-t border-gray-100">
          <a href="<%= configurations_users_path %>"
             class="inline-flex items-center gap-1 px-4 py-2 border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 transition-colors">
            <span class="material-icons text-base">cancel</span>
            Cancelar
          </a>

          <button type="button"
                  data-users-edit-target="testCredBtn"
                  data-action="click->users-edit#testCredentials"
                  disabled
                  class="inline-flex items-center gap-1 px-4 py-2 border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
            <span data-users-edit-target="testCredIcon" class="material-icons text-base">wifi_tethering</span>
            <span data-users-edit-target="testCredLabel">Probar credenciales</span>
          </button>

          <button type="button"
                  data-users-edit-target="submitBtn"
                  data-action="click->users-edit#updateUser"
                  class="inline-flex items-center gap-1 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
            <span class="material-icons text-base">update</span>
            Actualizar
          </button>
        </div>

      </div>
    </div>
  </div>

</div>
