<% content_for :title, "Crear Factura Proveedor" %>
<% content_for :page_title, "Búsqueda de documentos Aceptados" %>

<div data-controller="documents-reception-create"
     data-documents-reception-create-doc-id-value="<%= params[:id] %>"
     data-testid="create-reception-page"
     class="p-6 flex flex-col h-full gap-4">

  <%# ──────────────────────────────────────────────────── %>
  <%# ACORDEÓN: Recepción de Documentos (solo si shouldRecept) %>
  <%# ──────────────────────────────────────────────────── %>
  <div data-documents-reception-create-target="receptAccordion"
       data-testid="recept-accordion"
       class="hidden bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">

    <button type="button"
            data-action="click->documents-reception-create#toggleReceptAccordion"
            class="w-full flex items-center justify-between px-5 py-4 text-left">
      <span class="text-sm font-semibold text-gray-800">Recepción de Documentos</span>
      <span data-documents-reception-create-target="receptAccordionIcon"
            class="material-icons text-gray-500 transition-transform duration-200">expand_more</span>
    </button>

    <div data-documents-reception-create-target="receptAccordionBody" class="px-5 pb-5">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

        <%# Mensaje %>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Seleccione la respuesta <span class="text-red-500">*</span></label>
          <select data-documents-reception-create-target="receptMensaje"
                  data-action="change->documents-reception-create#onReceptMensajeChange"
                  data-testid="recept-mensaje"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
            <option value="">-- Seleccione --</option>
            <option value="1">Aceptado</option>
            <option value="2">Aceptar Parcialmente</option>
            <option value="3">Rechazado</option>
          </select>
          <p data-documents-reception-create-target="errorReceptMensaje"
             class="hidden mt-1 text-xs text-red-600">La respuesta es requerida.</p>
        </div>

        <%# Condición Impuesto %>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Condición Impuesto <span class="text-red-500">*</span></label>
          <select data-documents-reception-create-target="receptCondicionImpuesto"
                  data-action="change->documents-reception-create#onReceptCondicionChange"
                  data-testid="recept-condicion-impuesto"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
            <option value="01">01 — Genera crédito IVA</option>
            <option value="02">02 — Genera crédito parcial del IVA</option>
            <option value="03">03 — Bienes de capital</option>
            <option value="04">04 — Gasto corriente no genera crédito</option>
            <option value="05">05 — Proporcionalidad</option>
          </select>
        </div>

        <%# TaxFactor %>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Factor %</label>
          <input type="text"
                 disabled
                 data-documents-reception-create-target="receptTaxFactor"
                 data-testid="recept-tax-factor"
                 placeholder="Factor %"
                 class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-gray-100 text-gray-400 cursor-not-allowed">
          <p data-documents-reception-create-target="errorReceptTaxFactor"
             class="hidden mt-1 text-xs text-red-600">El factor de impuesto es requerido.</p>
        </div>

        <%# Código Actividad %>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Código Actividad <span class="text-red-500">*</span></label>
          <select data-documents-reception-create-target="receptCodigoActividad"
                  data-testid="recept-codigo-actividad"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
            <option value="">-- Seleccione --</option>
          </select>
          <p data-documents-reception-create-target="errorReceptCodigoActividad"
             data-testid="error-codigo-actividad"
             class="hidden mt-1 text-xs text-red-600">El código de actividad es requerido.</p>
        </div>

      </div>

      <%# Detalle Mensaje (full width) %>
      <div class="mt-4">
        <label class="block text-xs font-medium text-gray-600 mb-1">Mensaje</label>
        <textarea data-documents-reception-create-target="receptDetalleMensaje"
                  data-testid="recept-detalle-mensaje"
                  rows="4"
                  maxlength="254"
                  placeholder="Detalle del mensaje (opcional)"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"></textarea>
        <p data-documents-reception-create-target="errorReceptDetalleMensaje"
           class="hidden mt-1 text-xs text-red-600">El detalle del mensaje es requerido.</p>
      </div>

      <%# Botón Previsualizar %>
      <div class="mt-4 flex justify-end">
        <button type="button"
                data-action="click->documents-reception-create#previewReceptDoc"
                data-testid="btn-previsualizar"
                class="inline-flex items-center gap-1 px-4 py-2 border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 transition-colors">
          <span class="material-icons text-base">print</span>
          Previsualizar
        </button>
      </div>
    </div>
  </div>

  <%# ──────────────────────────────────────────────────── %>
  <%# OVERLAY DE CARGA %>
  <%# ──────────────────────────────────────────────────── %>
  <%= render 'shared/overlay_loader',
        ctrl:    'documents-reception-create',
        message: 'Cargando...' %>

  <%# ──────────────────────────────────────────────────── %>
  <%# TABS %>
  <%# ──────────────────────────────────────────────────── %>
  <div data-documents-reception-create-target="tabsContainer"
       class="hidden flex-1 flex flex-col min-h-0 bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">

    <%# Tab headers %>
    <div class="flex border-b border-gray-200 flex-shrink-0">
      <button type="button"
              data-documents-reception-create-target="tabBtnCabecera"
              data-action="click->documents-reception-create#switchTab"
              data-tab="cabecera"
              data-testid="tab-cabecera"
              class="tab-btn px-5 py-3 text-sm font-medium text-blue-600 border-b-2 border-blue-600 bg-white transition-colors">
        Cabecera
      </button>
      <button type="button"
              data-documents-reception-create-target="tabBtnLineas"
              data-action="click->documents-reception-create#switchTab"
              data-tab="lineas"
              data-testid="tab-lineas"
              class="tab-btn hidden px-5 py-3 text-sm font-medium text-gray-500 border-b-2 border-transparent hover:text-gray-700 hover:border-gray-300 transition-colors">
        Líneas
      </button>
      <button type="button"
              data-documents-reception-create-target="tabBtnOtrosCargos"
              data-action="click->documents-reception-create#switchTab"
              data-tab="otros-cargos"
              data-testid="tab-otros-cargos"
              class="tab-btn hidden px-5 py-3 text-sm font-medium text-gray-500 border-b-2 border-transparent hover:text-gray-700 hover:border-gray-300 transition-colors">
        Otros Cargos
      </button>
    </div>

    <%# ── TAB: CABECERA ─────────────────────────────── %>
    <div data-documents-reception-create-target="tabCabecera"
         class="flex-1 flex flex-col min-h-0">
      <div class="flex-1 overflow-y-auto p-4">

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-4">

        <%# RefDocType %>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Tipo documento de referencia</label>
          <select data-documents-reception-create-target="selectRefDocType"
                  data-action="change->documents-reception-create#onRefDocTypeChange"
                  data-testid="select-ref-doc-type"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
            <option value="">-- Ninguno --</option>
          </select>
        </div>

        <%# RefDocEntry (autocomplete) %>
        <div class="relative">
          <label class="block text-xs font-medium text-gray-600 mb-1">Número documento de referencia</label>
          <input type="text"
                 disabled
                 data-documents-reception-create-target="inputRefDocEntry"
                 data-action="input->documents-reception-create#onRefDocEntryInput"
                 data-testid="input-ref-doc-entry"
                 placeholder="Buscar por número, código o nombre de proveedor"
                 class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-gray-100 text-gray-400 cursor-not-allowed">
          <div data-documents-reception-create-target="refDocAutocompleteList"
               data-testid="ref-doc-autocomplete-list"
               class="hidden absolute z-20 w-full mt-1 bg-white border border-gray-200 rounded-lg shadow-lg max-h-48 overflow-y-auto text-sm">
          </div>
          <p data-documents-reception-create-target="loadingRefDoc"
             class="hidden mt-1 text-xs text-gray-500">
            <span class="material-icons text-xs align-middle animate-spin">refresh</span>
            Buscando documentos...
          </p>
        </div>

        <%# Cerrar documento de referencia %>
        <div class="flex items-center gap-2 col-span-full">
          <input type="checkbox"
                 disabled
                 data-documents-reception-create-target="checkCloseRefDoc"
                 data-testid="check-close-ref-doc"
                 class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500">
          <label class="text-sm text-gray-700">Cerrar documento de referencia</label>
        </div>

        <%# CardCode (autocomplete proveedores) %>
        <div class="relative">
          <label class="block text-xs font-medium text-gray-600 mb-1">Código proveedor <span class="text-red-500">*</span></label>
          <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden focus-within:ring-2 focus-within:ring-blue-500 bg-white">
            <input type="text"
                   data-documents-reception-create-target="inputCardCode"
                   data-action="input->documents-reception-create#onCardCodeInput focus->documents-reception-create#onCardCodeFocus"
                   data-testid="input-card-code"
                   placeholder="Código o nombre de proveedor"
                   class="flex-1 px-3 py-2 text-sm bg-transparent outline-none">
            <button type="button"
                    data-action="click->documents-reception-create#refreshData"
                    data-testid="btn-refresh"
                    data-tooltip="Refrescar Datos"
                    class="self-stretch flex items-center px-2 border-l border-gray-200 text-blue-600 hover:bg-blue-50 transition-colors flex-shrink-0">
              <span class="material-icons text-base leading-none">autorenew</span>
            </button>
          </div>
          <div data-documents-reception-create-target="supplierAutocompleteList"
               data-testid="autocomplete-supplier-list"
               class="hidden absolute z-20 w-full mt-1 bg-white border border-gray-200 rounded-lg shadow-lg max-h-48 overflow-y-auto text-sm">
          </div>
          <p data-documents-reception-create-target="errorCardCode"
             data-testid="error-card-code"
             class="hidden mt-1 text-xs text-red-600">Seleccione un proveedor.</p>
        </div>

        <%# DocDate %>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Fecha contabilización</label>
          <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden focus-within:ring-2 focus-within:ring-blue-500 bg-white">
            <input type="date"
                   data-documents-reception-create-target="inputDocDate"
                   data-testid="input-doc-date"
                   class="flex-1 px-3 py-2 text-sm bg-transparent outline-none">
            <button type="button"
                    data-action="click->documents-reception-create#setToday"
                    data-field="inputDocDate"
                    data-testid="btn-today-doc-date"
                    class="self-stretch flex items-center px-3 border-l border-gray-200 text-xs font-medium text-blue-600 hover:bg-blue-50 transition-colors flex-shrink-0">
              Hoy
            </button>
          </div>
        </div>

        <%# CardName %>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Nombre</label>
          <input type="text"
                 data-documents-reception-create-target="inputCardName"
                 data-testid="input-card-name"
                 placeholder="Nombre del proveedor"
                 class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>

        <%# DocDueDate %>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Fecha vencimiento</label>
          <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden focus-within:ring-2 focus-within:ring-blue-500 bg-white">
            <input type="date"
                   data-documents-reception-create-target="inputDocDueDate"
                   data-testid="input-doc-due-date"
                   class="flex-1 px-3 py-2 text-sm bg-transparent outline-none">
            <button type="button"
                    data-action="click->documents-reception-create#setToday"
                    data-field="inputDocDueDate"
                    class="self-stretch flex items-center px-3 border-l border-gray-200 text-xs font-medium text-blue-600 hover:bg-blue-50 transition-colors flex-shrink-0">
              Hoy
            </button>
          </div>
        </div>

        <%# NumAtCard %>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Referencia</label>
          <input type="text"
                 data-documents-reception-create-target="inputNumAtCard"
                 data-testid="input-num-at-card"
                 placeholder="Número de referencia del proveedor"
                 class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>

        <%# TaxDate %>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Fecha XML</label>
          <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden focus-within:ring-2 focus-within:ring-blue-500 bg-white">
            <input type="date"
                   data-documents-reception-create-target="inputTaxDate"
                   data-action="change->documents-reception-create#onTaxDateChange"
                   data-testid="input-tax-date"
                   class="flex-1 px-3 py-2 text-sm bg-transparent outline-none">
            <button type="button"
                    data-action="click->documents-reception-create#setToday"
                    data-field="inputTaxDate"
                    class="self-stretch flex items-center px-3 border-l border-gray-200 text-xs font-medium text-blue-600 hover:bg-blue-50 transition-colors flex-shrink-0">
              Hoy
            </button>
          </div>
        </div>

        <%# DocCur (readonly) %>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Moneda</label>
          <input type="text"
                 readonly
                 data-documents-reception-create-target="inputDocCur"
                 data-testid="input-doc-cur"
                 placeholder="Moneda"
                 class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm bg-gray-50 outline-none cursor-default text-gray-700">
        </div>

      </div>

      <%# UDFs dinámicos %>
      <div data-documents-reception-create-target="udfsContainer"
           class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 mb-4">
      </div>

      <%# Tabla de líneas (read-only, llena desde tab Líneas) %>
      <div class="mb-4 border border-gray-200 rounded-xl overflow-hidden">
        <div data-documents-reception-create-target="apInvoiceLinesTable"></div>
      </div>

      <%# Comentario + Totales %>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-0">

        <%# Comentario %>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Comentario</label>
          <textarea data-documents-reception-create-target="inputComments"
                    data-action="input->documents-reception-create#onCommentsInput"
                    data-testid="input-comments"
                    rows="5"
                    maxlength="254"
                    placeholder="Comentario"
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"></textarea>
          <p class="mt-1 text-xs text-gray-400">
            <span data-documents-reception-create-target="commentsCharCount"
                  data-testid="comments-char-count">0</span> / 254
          </p>
        </div>

        <%# Totales %>
        <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
          <table class="w-full text-sm">
            <tbody>
              <tr class="border-b border-gray-200">
                <td class="py-1.5 text-xs text-gray-600 font-medium">SubTotal:</td>
                <td data-documents-reception-create-target="totalsSubtotal"
                    data-testid="totals-subtotal"
                    class="py-1.5 text-xs text-gray-800 text-right font-semibold">₡ 0.00</td>
              </tr>
              <tr class="border-b border-gray-200">
                <td class="py-1.5 text-xs text-gray-600 font-medium">Total otros cargos:</td>
                <td data-documents-reception-create-target="totalsOtrosCargos"
                    class="py-1.5 text-xs text-gray-800 text-right font-semibold">₡ 0.00</td>
              </tr>
              <tr class="border-b border-gray-200">
                <td class="py-1.5 text-xs text-gray-600 font-medium">Impuestos:</td>
                <td data-documents-reception-create-target="totalsImpuestos"
                    data-testid="totals-impuestos"
                    class="py-1.5 text-xs text-gray-800 text-right font-semibold">₡ 0.00</td>
              </tr>
              <tr class="border-b border-gray-200">
                <td class="py-1.5 text-xs text-gray-600 font-medium">Descuento:</td>
                <td data-documents-reception-create-target="totalsDescuento"
                    data-testid="totals-descuento"
                    class="py-1.5 text-xs text-gray-800 text-right font-semibold">₡ 0.00</td>
              </tr>
              <tr>
                <td class="py-2 text-sm text-gray-800 font-bold">Total:</td>
                <td data-documents-reception-create-target="totalsTotal"
                    data-testid="totals-total"
                    class="py-2 text-sm text-blue-700 text-right font-bold">₡ 0.00</td>
              </tr>
            </tbody>
          </table>
        </div>

      </div>

      </div>

      <%# Footer fijo dentro del tab Cabecera %>
      <div class="flex-shrink-0 px-5 py-3 border-t border-gray-100 bg-white flex justify-end gap-3">
        <button type="button"
                data-action="click->documents-reception-create#cancel"
                class="inline-flex items-center gap-1 px-4 py-2 border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 transition-colors">
          <span class="material-icons text-base">cancel</span>
          Cancelar
        </button>
        <button type="button"
                disabled
                data-documents-reception-create-target="btnCreateDraft"
                data-action="click->documents-reception-create#createDraft"
                data-testid="btn-create-draft"
                class="inline-flex items-center gap-1 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
          <span class="material-icons text-base">post_add</span>
          Crear borrador en SAP
        </button>
        <button type="button"
                disabled
                data-documents-reception-create-target="btnCreateSap"
                data-action="click->documents-reception-create#createInSap"
                data-testid="btn-create-sap"
                class="inline-flex items-center gap-1 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
          <span class="material-icons text-base">post_add</span>
          Crear en SAP
        </button>
      </div>

    </div>

    <%# ── TAB: LÍNEAS ─────────────────────────────────── %>
    <div data-documents-reception-create-target="tabLineas"
         class="hidden flex-1 overflow-y-auto p-6 space-y-6">

      <%# Tabla XML %>
      <div>
        <h4 class="text-sm font-semibold text-gray-700 mb-2">Líneas del XML</h4>
        <div class="border border-gray-200 rounded-xl overflow-hidden">
          <div data-documents-reception-create-target="xmlLinesTable" data-testid="xml-lines-table"></div>
        </div>
      </div>

      <%# Tabla líneas SAP %>
      <div>
        <h4 class="text-sm font-semibold text-gray-700 mb-2">Líneas a enviar a SAP</h4>
        <div class="border border-gray-200 rounded-xl overflow-hidden">
          <div data-documents-reception-create-target="sapLinesTable" data-testid="sap-lines-table"></div>
        </div>
      </div>

    </div>

    <%# ── TAB: OTROS CARGOS ──────────────────────────── %>
    <div data-documents-reception-create-target="tabOtrosCargos"
         class="hidden flex-1 overflow-y-auto p-6 space-y-6">

      <%# Tabla fuente: líneas XML de cargos %>
      <div>
        <h4 class="text-sm font-semibold text-gray-700 mb-3">Otros Cargos del XML</h4>
        <div class="border border-gray-200 rounded-xl overflow-hidden">
          <div data-documents-reception-create-target="otrosCargosTable"></div>
        </div>
      </div>

      <%# Tabla resultado A: líneas para envío a SAP — visible solo en modo FreightCharges=1 %>
      <div data-documents-reception-create-target="ocApLinesSection" class="hidden">
        <div class="flex items-center justify-between mb-3">
          <h4 class="text-sm font-semibold text-gray-700">Líneas para envío a SAP</h4>
          <span class="text-xs text-gray-400">Seleccione filas y presione el ícono eliminar para quitar varias</span>
        </div>
        <div class="border border-gray-200 rounded-xl overflow-hidden">
          <div data-documents-reception-create-target="ocApLinesTable"></div>
        </div>
      </div>

      <%# Tabla resultado B: cargos adicionales SAP — visible solo en modo FreightCharges=2 %>
      <div data-documents-reception-create-target="ocChargesSection" class="hidden">
        <div class="flex items-center justify-between mb-3">
          <h4 class="text-sm font-semibold text-gray-700">Cargos adicionales para SAP</h4>
          <span class="text-xs text-gray-400">Seleccione filas y presione el ícono eliminar para quitar varias</span>
        </div>
        <div class="border border-gray-200 rounded-xl overflow-hidden">
          <div data-documents-reception-create-target="ocChargesTable"></div>
        </div>
      </div>

    </div>

  </div>

  <%# ──────────────────────────────────────────────────── %>
  <%# MODAL: Selección de moneda (currency mismatch) %>
  <%# ──────────────────────────────────────────────────── %>
  <div data-documents-reception-create-target="currencyMismatchModal"
       data-testid="currency-mismatch-modal"
       class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-md p-6">
      <h3 class="text-base font-semibold text-gray-800 mb-2">Moneda no encontrada</h3>
      <p class="text-sm text-gray-600 mb-4">
        La moneda del XML (<strong data-documents-reception-create-target="currencyMismatchXmlCode"></strong>)
        no está configurada en la compañía. Seleccione la moneda con la que desea continuar:
      </p>
      <div class="mb-4">
        <label class="block text-xs font-medium text-gray-600 mb-1">Moneda</label>
        <select data-documents-reception-create-target="currencyMismatchSelect"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
          <option value="">-- Seleccione --</option>
        </select>
      </div>
      <label class="flex items-center gap-2 mb-6 cursor-pointer">
        <input type="checkbox"
