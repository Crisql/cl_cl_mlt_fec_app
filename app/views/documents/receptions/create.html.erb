      <h3 class="text-base font-semibold text-gray-800 mb-2">Tolerancia no configurada</h3>
      <p class="text-sm text-gray-600 mb-4">
        La moneda del documento (<strong data-documents-reception-create-target="toleranceDocCurrency"></strong>)
        no tiene una tolerancia configurada. Seleccione la tolerancia con la que desea continuar:
      </p>
      <div class="mb-6">
        <label class="block text-xs font-medium text-gray-600 mb-1">Tolerancia</label>
        <select data-documents-reception-create-target="toleranceSelect"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
          <option value="">-- Seleccione --</option>
        </select>
      </div>
      <div class="flex justify-end gap-3">
        <button type="button"
                data-action="click->documents-reception-create#cancelTolerance"
                class="px-4 py-2 text-sm font-medium text-gray-700 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
          Cancelar
        </button>
        <button type="button"
                data-action="click->documents-reception-create#confirmTolerance"
                class="px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors">
          Continuar
        </button>
      </div>
    </div>
  </div>

  <%# ──────────────────────────────────────────────────── %>
