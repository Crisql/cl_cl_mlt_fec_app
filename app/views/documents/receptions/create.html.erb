      </div>

      <div class="relative">
        <label class="block text-xs font-medium text-gray-600 mb-1">Proyecto</label>
        <input type="text"
               data-documents-reception-create-target="itemInputProject"
               data-action="input->documents-reception-create#onItemProjectInput focus->documents-reception-create#onItemProjectFocus"
