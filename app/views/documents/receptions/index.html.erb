<% content_for :title, "Documentos recepcionados" %>
<% content_for :page_title, "Búsqueda de documentos recepcionados" %>

<div data-controller="documents-receptions documents-reception"
     data-action="documents-reception:done->documents-receptions#reloadTable"
     data-testid="documents-receptions-page"
     class="p-6 flex flex-col h-full gap-4">

  <%# ---------------------------------------------------------------- %>
  <%# FORMULARIO DE FILTROS %>
  <%# ---------------------------------------------------------------- %>
  <div class="flex-shrink-0 bg-white rounded-xl shadow-sm border border-gray-100 p-5">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 items-end">

      <%# Fecha de Inicio %>
      <div class="flex flex-col gap-1">
        <label class="text-xs font-medium text-gray-500 uppercase tracking-wide">Fecha de Inicio</label>
        <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden focus-within:ring-2 focus-within:ring-blue-500 bg-white">
          <input type="date"
                 data-documents-receptions-target="inputStartDate"
                 data-testid="input-start-date"
                 class="flex-1 px-3 py-2 text-sm bg-transparent outline-none">
          <button type="button"
                  data-action="click->documents-receptions#setTodayStartDate"
                  data-testid="btn-today-start"
                  class="self-stretch flex items-center px-3 border-l border-gray-200 text-xs font-medium text-blue-600 hover:bg-blue-50 transition-colors flex-shrink-0">
            Hoy
          </button>
        </div>
      </div>

      <%# Fecha Final %>
      <div class="flex flex-col gap-1">
        <label class="text-xs font-medium text-gray-500 uppercase tracking-wide">Fecha Final</label>
        <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden focus-within:ring-2 focus-within:ring-blue-500 bg-white">
          <input type="date"
                 data-documents-receptions-target="inputEndDate"
                 data-testid="input-end-date"
                 class="flex-1 px-3 py-2 text-sm bg-transparent outline-none">
          <button type="button"
                  data-action="click->documents-receptions#setTodayEndDate"
                  data-testid="btn-today-end"
                  class="self-stretch flex items-center px-3 border-l border-gray-200 text-xs font-medium text-blue-600 hover:bg-blue-50 transition-colors flex-shrink-0">
            Hoy
          </button>
        </div>
      </div>

      <%# Tipo de fechas (checkbox useXMLDates) %>
      <div class="flex flex-col justify-end">
        <label class="flex items-center gap-2 cursor-pointer select-none pb-2">
          <input type="checkbox"
                 data-documents-receptions-target="checkUseXMLDates"
                 data-action="change->documents-receptions#toggleUseXMLDates"
                 data-testid="check-use-xml-dates"
                 class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500">
          <span class="text-sm text-gray-700">¿Fechas de Emisión de Documento?</span>
        </label>
        <p class="text-xs text-gray-500">
          Tipo de fecha:
          <span data-documents-receptions-target="labelDateType"
                data-testid="label-date-type"
                class="font-semibold text-gray-700">Recepción</span>
        </p>
      </div>

      <%# Petición (MessageType) %>
      <div class="flex flex-col gap-1">
        <label class="text-xs font-medium text-gray-500 uppercase tracking-wide">Petición</label>
        <select data-documents-receptions-target="selectMessageType"
                data-testid="select-message-type"
                class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
          <option value="0" selected>Todos</option>
          <option value="1">Aceptado</option>
          <option value="2">Aceptado Parcialmente</option>
          <option value="3">Rechazado</option>
        </select>
      </div>

      <%# Estado %>
      <div class="flex flex-col gap-1">
        <label class="text-xs font-medium text-gray-500 uppercase tracking-wide">Estado</label>
        <select data-documents-receptions-target="selectStatus"
                data-testid="select-status"
                class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
          <option value="0" selected>Todos</option>
          <option value="1">Aceptado</option>
          <option value="2">Procesando</option>
          <option value="3">En Hacienda</option>
          <option value="4">Rechazado</option>
          <option value="5">Error</option>
          <option value="7">Obtenido del Correo</option>
          <option value="8">Obtenido Correo Automático</option>
        </select>
      </div>

      <%# Nombre del Emisor %>
      <div class="flex flex-col gap-1">
        <label class="text-xs font-medium text-gray-500 uppercase tracking-wide">Nombre del Emisor</label>
        <input type="text"
               data-documents-receptions-target="inputNombreEmisor"
               data-testid="input-nombre-emisor"
               placeholder="Nombre del emisor"
               class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>

      <%# Clave %>
      <div class="flex flex-col gap-1">
        <label class="text-xs font-medium text-gray-500 uppercase tracking-wide">Clave</label>
        <input type="text"
               data-documents-receptions-target="inputClave"
               data-testid="input-clave"
               placeholder="Clave del comprobante"
               class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>

      <%# Cédula Emisor %>
      <div class="flex flex-col gap-1">
        <label class="text-xs font-medium text-gray-500 uppercase tracking-wide">Cédula Emisor</label>
        <input type="text"
               data-documents-receptions-target="inputCedula"
               data-testid="input-cedula"
               placeholder="Cédula del emisor"
               maxlength="12"
               class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>

      <%# Consecutivo Emisor %>
      <div class="flex flex-col gap-1">
        <label class="text-xs font-medium text-gray-500 uppercase tracking-wide">Consecutivo Emisor</label>
        <input type="text"
               data-documents-receptions-target="inputConsecutivoEmisor"
               data-testid="input-consecutivo-emisor"
               placeholder="N° Consecutivo del emisor"
               class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>

      <%# Tipo de Documento %>
      <div class="flex flex-col gap-1">
        <label class="text-xs font-medium text-gray-500 uppercase tracking-wide">Tipo de Documento</label>
        <select data-documents-receptions-target="selectDocType"
                data-testid="select-doc-type"
                class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
          <option value="01" selected>Factura Electrónica</option>
          <option value="02">Nota de Débito</option>
          <option value="03">Nota de Crédito</option>
          <option value="04">Tiquete Electrónico</option>
          <option value="08">Factura Electrónica de Compra</option>
          <option value="09">Factura Electrónica de Exportación</option>
          <option value="10">Recibo Electrónico de Pago</option>
        </select>
      </div>

      <%# Bandeja (se carga dinámicamente) %>
      <div class="flex flex-col gap-1">
        <label class="text-xs font-medium text-gray-500 uppercase tracking-wide">Bandeja</label>
        <select data-documents-receptions-target="selectBandeja"
                data-testid="select-bandeja"
                class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
          <option value="">Todas</option>
        </select>
      </div>

      <%# Código de Moneda (con autocomplete) %>
      <div class="flex flex-col gap-1">
        <label class="text-xs font-medium text-gray-500 uppercase tracking-wide">Código de Moneda</label>
        <input type="text"
               data-documents-receptions-target="inputCodigoMoneda"
               data-action="input->documents-receptions#onCodigoMonedaInput"
               data-testid="input-codigo-moneda"
               placeholder="Ej: CRC, USD"
               list="currency-codes-list"
               class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        <datalist id="currency-codes-list"></datalist>
      </div>

      <%# Botones Recepcionar / Consultar — fila propia, alineados a la derecha %>
      <div class="col-span-full flex justify-end">
        <div class="flex gap-2 w-full sm:w-[calc(50%-0.5rem)] lg:w-[calc(33.333%-0.667rem)] xl:w-[calc(25%-0.75rem)]">
          <button type="button"
                  data-action="click->documents-receptions#search"
                  data-testid="btn-search"
                  class="inline-flex items-center gap-1 px-4 py-2 border border-blue-600 text-blue-600 text-sm font-medium rounded-lg hover:bg-blue-50 transition-colors flex-1 justify-center">
            <span class="material-icons text-base">filter_alt</span>
            Consultar
          </button>
          <button type="button"
                  data-documents-receptions-target="btnRecepcionar"
                  data-action="click->documents-reception#openPanel"
                  data-testid="btn-recepcionar"
                  class="hidden inline-flex items-center gap-1 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors flex-1 justify-center">
            <span class="material-icons text-base">file_upload</span>
            Recepcionar
          </button>
        </div>
      </div>

    </div>
  </div>

  <%# ---------------------------------------------------------------- %>
  <%# TOOLBAR DE LA TABLA %>
  <%# ---------------------------------------------------------------- %>
  <div class="flex-shrink-0 flex items-center justify-end gap-3 -mb-3">

    <%# Botones de acción — ícono que despliega el texto en hover (slide) %>
    <div class="flex gap-2">
    <button type="button"
            data-documents-receptions-target="btnChart"
            data-action="click->documents-receptions#openChartModal"
            data-testid="btn-chart"
            title="Más Información"
            class="hidden group inline-flex items-center cursor-pointer px-1.5 py-1.5 text-blue-600 text-xs font-medium rounded-md hover:bg-blue-50 transition-colors overflow-hidden">
      <span class="material-icons text-lg leading-none flex-shrink-0">query_stats</span>
      <span class="max-w-0 opacity-0 group-hover:max-w-xs group-hover:opacity-100 group-hover:ml-1 group-hover:mr-0.5 overflow-hidden whitespace-nowrap transition-all duration-500 ease-out group-hover:duration-1000 group-hover:ease-in-out">Más Información</span>
    </button>

    <button type="button"
            data-documents-receptions-target="btnBulkDownload"
            data-action="click->documents-receptions#bulkDownload"
            data-testid="btn-bulk-download"
            title="Descarga Masiva"
            class="hidden group inline-flex items-center cursor-pointer px-1.5 py-1.5 text-blue-600 text-xs font-medium rounded-md hover:bg-blue-50 transition-colors overflow-hidden">
      <span class="material-icons text-lg leading-none flex-shrink-0">file_download</span>
      <span class="max-w-0 opacity-0 group-hover:max-w-xs group-hover:opacity-100 group-hover:ml-1 group-hover:mr-0.5 overflow-hidden whitespace-nowrap transition-all duration-500 ease-out group-hover:duration-1000 group-hover:ease-in-out">Descarga Masiva</span>
    </button>
    </div>

  </div>

  <%# ---------------------------------------------------------------- %>
  <%# TABLA TABULATOR (full-height) %>
  <%# ---------------------------------------------------------------- %>
  <div class="flex-1 min-h-0 bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div data-documents-receptions-target="table"
         data-testid="documents-receptions-table"
         class="h-full"></div>
  </div>

  <%# ---------------------------------------------------------------- %>
  <%# PANEL LATERAL: Recepcionar Documento %>
  <%# ---------------------------------------------------------------- %>
  <div data-documents-receptions-target="receptBackdrop"
       data-action="click->documents-receptions#closeReceptPanel"
       class="hidden fixed inset-0 z-40 bg-black/40"></div>

  <div data-documents-receptions-target="receptPanel"
       data-testid="recept-panel"
       class="fixed top-0 right-0 h-full w-full max-w-lg bg-white shadow-2xl z-50
              translate-x-full transition-transform duration-300 ease-in-out flex flex-col">

    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100 flex-shrink-0">
      <h3 class="text-base font-semibold text-gray-800">Previsualizar aceptación</h3>
      <button type="button"
              data-action="click->documents-receptions#closeReceptPanel"
              class="p-1 text-gray-400 hover:text-gray-600 rounded hover:bg-gray-100 transition-colors">
        <span class="material-icons text-xl">close</span>
      </button>
    </div>

    <div class="flex-1 overflow-y-auto px-6 py-5 space-y-4">

      <%# Nombre del Documento (readonly) %>
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Documento</label>
        <input type="text"
               data-documents-receptions-target="receptDocName"
               data-testid="recept-doc-name"
               readonly
               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm bg-gray-50 outline-none cursor-default text-gray-700">
      </div>

      <%# Mensaje %>
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Mensaje</label>
        <select data-documents-receptions-target="receptMensaje"
                data-testid="recept-mensaje"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
          <option value="1">Aceptado</option>
          <option value="2">Aceptado Parcialmente</option>
          <option value="3">Rechazado</option>
        </select>
      </div>

      <%# Condición de Impuesto %>
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Condición de Impuesto</label>
        <select data-documents-receptions-target="receptCondicionImpuesto"
                data-testid="recept-condicion-impuesto"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
          <option value="01">01 — Genera crédito IVA</option>
          <option value="02">02 — Proporción crédito IVA</option>
          <option value="03">03 — Bienes de capital</option>
          <option value="04">04 — Gasto o costo</option>
          <option value="05">05 — No genera crédito</option>
        </select>
      </div>

      <%# TaxFactor %>
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Factor de Impuesto</label>
        <input type="number"
               step="0.01"
               min="0"
               max="100"
               data-documents-receptions-target="receptTaxFactor"
               data-testid="recept-tax-factor"
               placeholder="0.00"
               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>

      <%# Código de Actividad %>
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Código de Actividad</label>
        <select data-documents-receptions-target="receptCodigoActividad"
                data-testid="recept-codigo-actividad"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
          <option value="">-- Seleccione --</option>
        </select>
      </div>

      <%# Detalle del Mensaje %>
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Detalle del mensaje</label>
        <textarea data-documents-receptions-target="receptDetalleMensaje"
                  data-action="input->documents-receptions#onReceptDetalleMensajeInput"
                  data-testid="recept-detalle-mensaje"
                  rows="4"
                  maxlength="160"
                  placeholder="Descripción del mensaje de recepción"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"></textarea>
        <div class="mt-1 flex items-start justify-between gap-3">
          <p data-documents-receptions-target="errorReceptDetalleMensaje"
             class="hidden text-xs text-red-500">El detalle del mensaje es requerido para esta respuesta</p>
          <p data-documents-receptions-target="counterReceptDetalleMensaje"
             class="ml-auto flex-shrink-0 text-xs text-gray-400">0/160</p>
        </div>
      </div>

    </div>

    <div class="px-6 py-4 border-t border-gray-100 flex justify-end gap-3 flex-shrink-0">
      <button type="button"
              data-action="click->documents-receptions#closeReceptPanel"
              data-testid="btn-recept-cancel"
              class="inline-flex items-center gap-1 px-4 py-2 border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 transition-colors">
        <span class="material-icons text-base">cancel</span>
        Cancelar
      </button>
      <button type="button"
              data-action="click->documents-receptions#saveFromReceptPanel"
              data-testid="btn-recept-submit"
              class="inline-flex items-center gap-1 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
        <span class="material-icons text-base">send</span>
        Enviar
      </button>
    </div>

  </div>

  <%# ---------------------------------------------------------------- %>
  <%# PANEL LATERAL: Consultar Información (igual que documents-issued) %>
  <%# ---------------------------------------------------------------- %>
  <div data-documents-receptions-target="infoPanelBackdrop"
       data-action="click->documents-receptions#closeInfoPanel"
       class="hidden fixed inset-0 z-40 bg-black/40"></div>

  <div data-documents-receptions-target="infoPanel"
       data-testid="info-panel"
       class="fixed top-0 right-0 h-full w-full max-w-md bg-white shadow-2xl z-50
              translate-x-full transition-transform duration-300 ease-in-out flex flex-col">

    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100 flex-shrink-0">
      <h3 class="text-base font-semibold text-gray-800">Información del documento</h3>
      <button type="button"
              data-action="click->documents-receptions#closeInfoPanel"
              class="p-1 text-gray-400 hover:text-gray-600 rounded hover:bg-gray-100 transition-colors">
        <span class="material-icons text-xl">close</span>
      </button>
    </div>

    <div class="flex-1 overflow-y-auto px-6 py-5 space-y-4">
      <div>
        <p class="text-xs font-medium text-gray-500 mb-0.5">Fecha de Emisión</p>
        <p data-documents-receptions-target="infoFechaEmision"
           data-testid="info-fecha-emision"
           class="text-sm text-gray-800"></p>
      </div>
      <div data-documents-receptions-target="infoDetalleMensajeSection" class="hidden">
        <p class="text-xs font-medium text-gray-500 mb-0.5">Detalle de Mensaje</p>
        <p data-documents-receptions-target="infoDetalleMensaje"
           class="text-sm text-gray-800 leading-relaxed break-words whitespace-pre-wrap"></p>
      </div>
      <div data-documents-receptions-target="infoErrorSection" class="hidden">
        <p class="text-xs font-medium text-gray-500 mb-2">Error interno</p>
        <div class="rounded-lg border border-red-200 bg-red-50 p-3">
          <p data-documents-receptions-target="infoError"
             data-testid="info-error"
             class="text-sm text-red-800 leading-relaxed break-all"></p>
        </div>
      </div>
      <div data-documents-receptions-target="infoErrorHaciendaSection" class="hidden">
        <p class="text-xs font-medium text-gray-500 mb-2">Respuesta Hacienda</p>
        <div data-documents-receptions-target="infoErrorHacienda"
             data-testid="info-error-hacienda"></div>
      </div>
    </div>

    <div class="px-6 py-4 border-t border-gray-100 flex justify-end flex-shrink-0">
      <button type="button"
              data-action="click->documents-receptions#closeInfoPanel"
              class="inline-flex items-center gap-1 px-4 py-2 border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 transition-colors">
        <span class="material-icons text-base">close</span>
        Cerrar
      </button>
    </div>
  </div>

  <%# ---------------------------------------------------------------- %>
  <%# MODAL: Información (genérico — bandeja, detalle mensaje) %>
  <%# ---------------------------------------------------------------- %>
  <div data-documents-receptions-target="infoModal"
       data-testid="info-modal"
       class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40">
    <div class="bg-white rounded-xl shadow-xl p-6 max-w-md w-full mx-4">
      <div class="flex items-center gap-3 mb-3">
        <span class="material-icons text-2xl text-blue-500">info</span>
        <h3 data-documents-receptions-target="infoTitle"
            data-testid="info-title"
            class="text-base font-semibold text-gray-800"></h3>
      </div>
      <p data-documents-receptions-target="infoBody"
         data-testid="info-body"
         class="text-sm text-gray-600 whitespace-pre-line mb-5"></p>
      <div class="flex justify-end">
        <button type="button"
                data-action="click->documents-receptions#closeInfoModal"
                class="inline-flex items-center gap-1 px-4 py-2 border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 transition-colors">
          <span class="material-icons text-base">close</span>
          Cerrar
        </button>
      </div>
    </div>
  </div>

  <%# ---------------------------------------------------------------- %>
  <%# PANEL LATERAL: Recepcionar documento (carga de XML) %>
  <%# ---------------------------------------------------------------- %>
  <div data-documents-reception-target="panelBackdrop"
       data-action="click->documents-reception#closePanel"
       class="hidden fixed inset-0 z-40 bg-black/40"></div>

  <div data-documents-reception-target="panel"
       data-testid="documents-reception-page"
       class="fixed top-0 right-0 h-full w-full max-w-lg bg-white shadow-2xl z-50
              translate-x-full transition-transform duration-300 ease-in-out flex flex-col">

    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100 flex-shrink-0">
      <h3 class="text-base font-semibold text-gray-800">Recepcionar documento</h3>
      <button type="button"
              data-action="click->documents-reception#closePanel"
              class="p-1 text-gray-400 hover:text-gray-600 rounded hover:bg-gray-100 transition-colors">
        <span class="material-icons text-xl">close</span>
      </button>
    </div>

    <div class="flex-1 overflow-y-auto px-6 py-5 relative">

      <%# Loader mientras se cargan los códigos de actividad %>
      <div data-documents-reception-target="panelLoader"
           class="absolute inset-0 flex items-center justify-center bg-white z-10">
        <svg class="animate-spin h-6 w-6 text-blue-600"
             xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10"
                  stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor"
                d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
      </div>

      <div class="grid grid-cols-1 gap-5">

        <%# Adjuntar documento %>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">
            Adjuntar documento <span class="text-red-500">*</span>
          </label>
          <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden focus-within:ring-2 focus-within:ring-blue-500 bg-gray-50">
            <input type="text"
                   data-documents-reception-target="inputAdjunto"
                   data-testid="input-adjunto"
                   readonly
                   placeholder="Seleccione un archivo .xml"
                   class="flex-1 px-3 py-2 text-sm bg-transparent outline-none cursor-default">
            <button type="button"
                    data-action="click->documents-reception#triggerFileInput"
                    data-testid="btn-upload"
                    data-tooltip="Adjuntar archivo"
                    class="self-stretch flex items-center px-3 border-l border-gray-200 text-blue-600 hover:bg-blue-50 transition-colors flex-shrink-0">
              <span class="material-icons text-base leading-none">cloud_upload</span>
            </button>
          </div>
          <input type="file"
                 data-documents-reception-target="fileInput"
                 data-action="change->documents-reception#onFileSelected"
                 data-testid="file-input"
                 accept=".xml"
                 class="hidden">
          <p data-documents-reception-target="errorAdjunto"
             class="hidden mt-1 text-xs text-red-500">Seleccione un archivo .xml válido</p>
        </div>

        <%# Seleccione la respuesta %>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">
            Seleccione la respuesta <span class="text-red-500">*</span>
          </label>
          <select data-documents-reception-target="selectMensaje"
                  data-action="change->documents-reception#onMensajeChange"
                  data-testid="select-mensaje"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
            <option value="1">Aceptado</option>
            <option value="2">Aceptar Parcialmente</option>
            <option value="3">Rechazado</option>
          </select>
        </div>

        <%# Condición Impuesto %>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">
            Condición Impuesto <span class="text-red-500">*</span>
          </label>
          <select data-documents-reception-target="selectCondicionImpuesto"
                  data-action="change->documents-reception#onCondicionImpuestoChange"
                  data-testid="select-condicion-impuesto"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
            <option value="01">Genera Credito IVA</option>
            <option value="02">Genera Crédito parcial del IVA</option>
            <option value="03">Bienes de Capital</option>
            <option value="04">Gasto corriente no genera crédito</option>
            <option value="05">Proporcionalidad</option>
          </select>
        </div>

        <%# Factor % %>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Factor %</label>
          <input type="text"
                 data-documents-reception-target="inputTaxFactor"
                 data-testid="input-tax-factor"
                 value="0"
                 disabled
                 placeholder="Factor %"
                 class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 disabled:bg-gray-100 disabled:text-gray-400 disabled:cursor-not-allowed">
          <p data-documents-reception-target="errorTaxFactor"
             class="hidden mt-1 text-xs text-red-500">El factor es requerido para esta condición</p>
        </div>

        <%# Código Actividad %>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">
            Código Actividad <span class="text-red-500">*</span>
          </label>
          <select data-documents-reception-target="inputCodigoActividad"
                  data-testid="input-codigo-actividad"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
            <option value="">-- Seleccione --</option>
          </select>
          <p data-documents-reception-target="errorCodigoActividad"
             class="hidden mt-1 text-xs text-red-500">El código de actividad es requerido</p>
        </div>

        <%# Detalle Mensaje %>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Detalle del mensaje</label>
          <textarea data-documents-reception-target="inputDetalleMensaje"
                    data-action="input->documents-reception#onDetalleMensajeInput"
                    data-testid="input-detalle-mensaje"
                    rows="5"
                    maxlength="160"
                    placeholder="Detalle del mensaje (requerido para rechazo parcial o total)"
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"></textarea>
          <div class="mt-1 flex items-start justify-between gap-3">
            <p data-documents-reception-target="errorDetalleMensaje"
               class="hidden text-xs text-red-500">El detalle del mensaje es requerido para esta respuesta</p>
            <p data-documents-reception-target="counterDetalleMensaje"
               class="ml-auto flex-shrink-0 text-xs text-gray-400">0/160</p>
          </div>
        </div>

      </div>
    </div>

    <div class="px-6 py-4 border-t border-gray-100 flex justify-end gap-3 flex-shrink-0">
      <button type="button"
              data-action="click->documents-reception#getPreview"
              data-testid="btn-preview"
              class="inline-flex items-center gap-1.5 px-4 py-2 border border-blue-600 text-blue-600 text-sm font-medium rounded-lg hover:bg-blue-50 transition-colors">
        <span class="material-icons text-base">print</span>
        Previsualizar
      </button>
      <button type="button"
              data-action="click->documents-reception#onSubmit"
              data-testid="btn-submit"
              class="inline-flex items-center gap-1.5 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
        <span class="material-icons text-base">send</span>
        Enviar
      </button>
    </div>
  </div>

  <%# ---------------------------------------------------------------- %>
  <%# PANEL LATERAL: Previsualización del Documento (sobre el panel de carga) %>
  <%# ---------------------------------------------------------------- %>
  <div data-documents-reception-target="previewBackdrop"
       data-action="click->documents-reception#closePreview"
       class="hidden fixed inset-0 z-[55] bg-black/40"></div>

  <div data-documents-reception-target="previewPanel"
       data-testid="preview-panel"
       class="fixed top-0 right-0 h-full w-full max-w-2xl bg-white shadow-2xl z-[60]
              translate-x-full transition-transform duration-300 ease-in-out flex flex-col">

    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100 flex-shrink-0">
      <h3 class="text-base font-semibold text-gray-800">Previsualización del Documento</h3>
      <button type="button"
              data-action="click->documents-reception#closePreview"
              class="p-1 text-gray-400 hover:text-gray-600 rounded hover:bg-gray-100 transition-colors">
        <span class="material-icons text-xl">close</span>
      </button>
    </div>

    <div class="flex-1 overflow-y-auto px-6 py-5 space-y-3">

      <%# Información del Documento %>
      <details class="border border-gray-200 rounded-lg" open>
        <summary class="px-4 py-3 text-sm font-semibold text-gray-700 cursor-pointer select-none hover:bg-gray-50 rounded-lg">
          Información del Documento
        </summary>
        <div class="px-4 pb-4 grid grid-cols-1 sm:grid-cols-2 gap-4 mt-2">
          <div>
            <p class="text-xs text-gray-500 mb-0.5">Número Consecutivo</p>
            <p data-documents-reception-target="previewNumeroConsecutivo" class="text-sm text-gray-800 font-medium">—</p>
          </div>
          <div>
            <p class="text-xs text-gray-500 mb-0.5">Fecha de Emisión</p>
            <p data-documents-reception-target="previewFechaEmision" class="text-sm text-gray-800 font-medium">—</p>
          </div>
          <div>
            <p class="text-xs text-gray-500 mb-0.5">Moneda</p>
            <p data-documents-reception-target="previewMoneda" class="text-sm text-gray-800 font-medium">—</p>
          </div>
          <div>
            <p class="text-xs text-gray-500 mb-0.5">Tipo de Cambio</p>
            <p data-documents-reception-target="previewTipoCambio" class="text-sm text-gray-800 font-medium">—</p>
          </div>
          <div class="sm:col-span-2">
            <p class="text-xs text-gray-500 mb-0.5">Clave</p>
            <p data-documents-reception-target="previewClave" class="text-sm text-gray-800 font-medium break-all">—</p>
          </div>
          <div>
            <p class="text-xs text-gray-500 mb-0.5">Plazo Crédito</p>
            <p data-documents-reception-target="previewPlazoCredito" class="text-sm text-gray-800 font-medium">—</p>
          </div>
        </div>
        <div data-documents-reception-target="previewMedioPago" class="px-4 pb-4 space-y-2"></div>
      </details>

      <%# Información del Emisor %>
      <details class="border border-gray-200 rounded-lg" open>
        <summary class="px-4 py-3 text-sm font-semibold text-gray-700 cursor-pointer select-none hover:bg-gray-50 rounded-lg">
          Información del Emisor
        </summary>
        <div class="px-4 pb-4 grid grid-cols-1 sm:grid-cols-2 gap-4 mt-2">
          <div>
            <p class="text-xs text-gray-500 mb-0.5">Nombre</p>
            <p data-documents-reception-target="previewEmsrNombre" class="text-sm text-gray-800 font-medium">—</p>
          </div>
          <div>
            <p class="text-xs text-gray-500 mb-0.5">Nombre Comercial</p>
            <p data-documents-reception-target="previewEmsrNombreComercial" class="text-sm text-gray-800 font-medium">—</p>
          </div>
          <div>
            <p class="text-xs text-gray-500 mb-0.5">Identificación</p>
            <p data-documents-reception-target="previewEmsrNumero" class="text-sm text-gray-800 font-medium">—</p>
          </div>
          <div>
            <p class="text-xs text-gray-500 mb-0.5">Correo Electrónico</p>
            <p data-documents-reception-target="previewEmsrCorreo" class="text-sm text-gray-800 font-medium">—</p>
          </div>
          <div>
            <p class="text-xs text-gray-500 mb-0.5">Teléfono</p>
            <p data-documents-reception-target="previewEmsrTelefono" class="text-sm text-gray-800 font-medium">—</p>
          </div>
        </div>
      </details>

      <%# Información del Receptor %>
      <details class="border border-gray-200 rounded-lg" open>
        <summary class="px-4 py-3 text-sm font-semibold text-gray-700 cursor-pointer select-none hover:bg-gray-50 rounded-lg">
          Información del Receptor
        </summary>
        <div class="px-4 pb-4 grid grid-cols-1 sm:grid-cols-2 gap-4 mt-2">
          <div>
            <p class="text-xs text-gray-500 mb-0.5">Nombre</p>
            <p data-documents-reception-target="previewRcprNombre" class="text-sm text-gray-800 font-medium">—</p>
          </div>
          <div>
            <p class="text-xs text-gray-500 mb-0.5">Nombre Comercial</p>
            <p data-documents-reception-target="previewRcprNombreComercial" class="text-sm text-gray-800 font-medium">—</p>
          </div>
          <div>
            <p class="text-xs text-gray-500 mb-0.5">Identificación</p>
            <p data-documents-reception-target="previewRcprNumero" class="text-sm text-gray-800 font-medium">—</p>
          </div>
          <div>
            <p class="text-xs text-gray-500 mb-0.5">Correo Electrónico</p>
            <p data-documents-reception-target="previewRcprCorreo" class="text-sm text-gray-800 font-medium">—</p>
          </div>
          <div>
            <p class="text-xs text-gray-500 mb-0.5">Teléfono</p>
            <p data-documents-reception-target="previewRcprTelefono" class="text-sm text-gray-800 font-medium">—</p>
          </div>
        </div>
      </details>

      <%# Detalle del Documento %>
      <details class="border border-gray-200 rounded-lg" open>
        <summary class="px-4 py-3 text-sm font-semibold text-gray-700 cursor-pointer select-none hover:bg-gray-50 rounded-lg">
          Detalle del Documento
        </summary>
        <div class="px-4 pb-4 mt-2 overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-200 text-xs text-gray-500">
                <th class="text-left pb-2 pr-3 font-medium">Código</th>
                <th class="text-left pb-2 pr-3 font-medium">Detalle</th>
                <th class="text-right pb-2 pr-3 font-medium">Cant.</th>
                <th class="text-right pb-2 pr-3 font-medium">Precio Unit.</th>
                <th class="text-right pb-2 font-medium">Total</th>
              </tr>
            </thead>
            <tbody data-documents-reception-target="previewDetalleBody">
              <tr><td colspan="5" class="text-center text-gray-400 py-3 text-xs">Sin líneas</td></tr>
            </tbody>
          </table>
        </div>
      </details>

      <%# Detalle de Cargos %>
      <details class="border border-gray-200 rounded-lg">
        <summary class="px-4 py-3 text-sm font-semibold text-gray-700 cursor-pointer select-none hover:bg-gray-50 rounded-lg">
          Detalle de Cargos
        </summary>
        <div class="px-4 pb-4 mt-2 overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-200 text-xs text-gray-500">
                <th class="text-left pb-2 pr-3 font-medium">Tipo</th>
                <th class="text-left pb-2 pr-3 font-medium">Descripción</th>
                <th class="text-right pb-2 font-medium">Monto</th>
              </tr>
            </thead>
            <tbody data-documents-reception-target="previewCargosBody">
              <tr><td colspan="3" class="text-center text-gray-400 py-3 text-xs">Sin cargos</td></tr>
            </tbody>
          </table>
        </div>
      </details>

      <%# Totales %>
      <details class="border border-gray-200 rounded-lg" open>
        <summary class="px-4 py-3 text-sm font-semibold text-gray-700 cursor-pointer select-none hover:bg-gray-50 rounded-lg">
          Totales
        </summary>
        <div class="px-4 pb-4 mt-2">
          <table class="w-full text-sm">
            <tbody data-documents-reception-target="previewTotalesBody" class="divide-y divide-gray-100">
            </tbody>
          </table>
        </div>
      </details>

    </div>

    <div class="px-6 py-4 border-t border-gray-100 flex justify-end flex-shrink-0">
      <button type="button"
              data-action="click->documents-reception#closePreview"
              class="inline-flex items-center gap-1 px-4 py-2 border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 transition-colors">
        <span class="material-icons text-base">close</span>
        Cerrar
      </button>
    </div>
  </div>

</div>
