<%# ════════════════ MODAL: CONFIRMAR ELIMINAR REFERENCIA ════════════════ %>
<div data-documents-create-target="confirmModal"
     class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40 p-4">
  <div class="bg-white rounded-xl shadow-2xl w-full max-w-md">
    <div class="px-6 py-5">
      <div class="flex items-start gap-3">
        <span class="material-icons text-amber-500">warning</span>
        <div>
          <h3 class="text-base font-semibold text-gray-800">Eliminar referencia</h3>
          <p class="mt-1 text-sm text-gray-600" data-documents-create-target="confirmMessage">¿Está seguro de eliminar esta referencia?</p>
        </div>
      </div>
    </div>
    <div class="px-6 py-4 border-t border-gray-100 flex justify-end gap-3">
      <button type="button" data-action="click->documents-create#closeConfirmModal"
              class="px-4 py-2 text-sm font-medium text-gray-700 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
        Cancelar
      </button>
      <button type="button" data-action="click->documents-create#confirmAction"
              class="px-4 py-2 bg-red-600 text-white text-sm font-medium rounded-lg hover:bg-red-700 transition-colors">
        Eliminar
      </button>
    </div>
  </div>
</div>

<%# ════════════════ MODAL: ÉXITO ════════════════ %>
<div data-documents-create-target="successModal"
     class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40 p-4">
  <div class="bg-white rounded-xl shadow-2xl w-full max-w-md">
    <div class="px-6 py-6 text-center">
      <span class="material-icons text-green-500 text-5xl">check_circle</span>
      <h3 class="mt-2 text-base font-semibold text-gray-800" data-documents-create-target="successTitle">Documento creado correctamente</h3>
      <p class="mt-1 text-sm text-gray-600" data-documents-create-target="successSubtitle"></p>
    </div>
    <div class="px-6 py-4 border-t border-gray-100 flex justify-center">
      <button type="button" data-action="click->documents-create#closeSuccessModal"
              class="px-5 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
        Aceptar
      </button>
    </div>
  </div>
</div>

<%# ════════════════ MODAL: ADVERTENCIA ════════════════ %>
<div data-documents-create-target="warningModal"
     class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40 p-4">
  <div class="bg-white rounded-xl shadow-2xl w-full max-w-md">
    <div class="px-6 py-6 text-center">
      <span class="material-icons text-amber-500 text-5xl">error_outline</span>
      <h3 class="mt-2 text-base font-semibold text-gray-800" data-documents-create-target="warningTitle">Documento creado con errores</h3>
      <p class="mt-1 text-sm text-gray-600" data-documents-create-target="warningSubtitle"></p>
    </div>
    <div class="px-6 py-4 border-t border-gray-100 flex justify-center">
      <button type="button" data-action="click->documents-create#closeWarningModal"
              class="px-5 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
        Aceptar
      </button>
    </div>
  </div>
</div>

<%# ════════════════ MODAL: ERROR ════════════════ %>
<div data-documents-create-target="errorModal"
     class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40 p-4">
  <div class="bg-white rounded-xl shadow-2xl w-full max-w-md">
    <div class="px-6 py-6 text-center">
      <span class="material-icons text-red-500 text-5xl">cancel</span>
      <h3 class="mt-2 text-base font-semibold text-gray-800">Error</h3>
      <p class="mt-1 text-sm text-gray-600" data-documents-create-target="errorMessage"></p>
    </div>
    <div class="px-6 py-4 border-t border-gray-100 flex justify-center">
      <button type="button" data-action="click->documents-create#closeErrorModal"
              class="px-5 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
        Aceptar
      </button>
    </div>
  </div>
</div>

<%# ════════════════ OVERLAY: CARGANDO ════════════════ %>
<div data-documents-create-target="loadingOverlay"
     class="hidden fixed inset-0 z-[60] flex items-center justify-center bg-black/30">
  <div class="bg-white rounded-xl shadow-2xl px-6 py-5 flex items-center gap-3">
    <span class="material-icons text-blue-600 animate-spin">autorenew</span>
    <span class="text-sm text-gray-700" data-documents-create-target="loadingMessage">Cargando…</span>
  </div>
</div>
