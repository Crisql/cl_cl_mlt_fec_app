<% content_for :title, "Inicio" %>
<% content_for :page_title, "Estadística" %>

<%# ---------------------------------------------------------------- %>
<%# Banner (oculto por defecto; home_controller.js lo muestra) %>
<%# ---------------------------------------------------------------- %>
<div data-controller="home"
     data-home-banner-url-value="/banner.json"
     data-testid="home-page">

  <div data-home-target="banner"
       data-testid="banner"
       class="relative mb-6 hidden">
    <button data-action="click->home#closeBanner"
            data-testid="banner-close"
            class="absolute top-2 right-2 z-10 bg-blue-600 text-white rounded-full w-7 h-7 flex items-center justify-center hover:bg-blue-700 transition-colors"
            aria-label="Cerrar banner">
      <span class="material-icons text-sm">clear</span>
    </button>
    <img data-home-target="bannerImage"
         data-action="click->home#viewBanner"
         data-testid="banner-image"
         src=""
         alt="Banner"
         class="w-full rounded-md border border-gray-200 cursor-pointer">
  </div>

  <%# ---------------------------------------------------------------- %>
  <%# Grid de gráficos — 3 filas × 2 columnas %>
  <%# ---------------------------------------------------------------- %>
  <div data-testid="charts-container"
       class="grid grid-cols-1 md:grid-cols-2 gap-6">

  </div>

</div>
