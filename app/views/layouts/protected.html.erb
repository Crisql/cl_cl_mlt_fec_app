<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="turbo-cache-control" content="no-cache">

    <%# ---------------------------------------------------------------- %>
    <%# Auth gate — guard SÍNCRONO, corre durante el parseo del <head>,    %>
    <%# antes de pintar el <body> y antes de que Stimulus (módulos ES      %>
    <%# diferidos) conecte. Si no hay sesión válida en localStorage,       %>
    <%# redirige a /login y la shell protegida NUNCA se renderiza →        %>
    <%# elimina el flash de menú/home vacío que dejaba un redirect async.  %>
    <%#                                                                     %>
    <%# Única fuente de la regla de validez para el cold load. La misma    %>
    <%# regla vive en isSessionValid() (vendor/clavisco/core), que usa el  %>
    <%# auth_guard_controller para la navegación Turbo in-app. Se inlinea  %>
    <%# (no se importa) porque debe ser bloqueante; un módulo ES sería     %>
    <%# diferido y pintaría la página antes de ejecutarse.                 %>
    <%# ---------------------------------------------------------------- %>
    <script>
      (function () {
        try {
          var raw = window.localStorage.getItem('Session');
          var s = raw ? JSON.parse(raw) : null;
          var valid = !!(s && s.access_token && (!s.expires_at || Date.now() < s.expires_at));
          if (!valid) window.location.replace('/login');
        } catch (e) {
          window.location.replace('/login');
        }
      })();
    </script>

    <title>Factura Electrónica</title>
    <% if content_for?(:title) %>
      <meta name="x-page-title" content="<%= yield(:title) + " | Factura Electrónica" %>">
    <% end %>

    <link rel="icon" type="image/x-icon" href="<%= asset_path('favicon.ico') %>">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <link rel="stylesheet" href="<%= asset_path('vendor/clavisco/tabulator/styles/tabulator.css') %>" data-turbo-track="reload">
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 text-gray-900 antialiased">
    <%# Toast container global %>
    <div id="toast-container" class="fixed top-4 right-4 z-[9999] flex flex-col space-y-2 pointer-events-none"></div>

    <%# ---------------------------------------------------------------- %>
    <%# Shell protegida — auth-guard + menu + company-selector %>
    <%# ---------------------------------------------------------------- %>
    <div data-controller="auth-guard company-selector session-sync"
         class="flex h-screen overflow-hidden">

      <%# ============================================================= %>
      <%# SIDEBAR %>
      <%# ============================================================= %>
      <%# Shell persistente — data-turbo-permanent conserva este nodo (y la instancia %>
      <%# del MenuController + su estado #expandedGroups) entre visitas Turbo, igual %>
      <%# que el app.component de Angular. No se re-renderiza al navegar. %>
      <aside id="app-sidebar"
             data-turbo-permanent
             data-controller="menu"
             data-testid="sidebar"
             class="flex flex-col bg-gray-900 text-white transition-all duration-300 w-64 flex-shrink-0">

        <%# Logo + título %>
        <div class="flex justify-center px-4 py-5 border-b border-gray-700">
          <svg id="logo-facturacion-electronica"
               class="logo-facturacion-electronica"
               xmlns="http://www.w3.org/2000/svg"
               viewBox="0 0 1080 339.01"
               role="img"
               aria-labelledby="logo-title logo-description"
               preserveAspectRatio="xMidYMid meet"
               data-testid="sidebar-logo">
  <title id="logo-title">CLAVISCO Facturación Electrónica</title>
  <desc id="logo-description">Logotipo de CLAVISCO para la solución de facturación electrónica.</desc>
  <defs>
    <style>
      .cls-1 {
        fill: var(--logo-accent, #f0ba40);
      }

      .cls-2 {
        fill: var(--logo-primary, #ffffff);
      }

      .cls-3 {
        fill: var(--logo-accent-secondary, #ecba44);
      }

      .cls-4 {
        fill: var(--logo-accent-tertiary, #ecb744);
      }
    </style>
  </defs>
