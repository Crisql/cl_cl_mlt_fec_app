        <%# Username %>
        <div class="px-4 py-3 border-b border-gray-700">
          <p class="text-xs text-gray-400">Usuario</p>
          <p data-menu-target="username"
             data-testid="sidebar-user"
             class="text-sm text-white truncate"></p>
        </div>

        <%# Nodos del menú %>
        <nav data-menu-target="nav"
             class="flex-1 overflow-y-auto py-2">
          <%# Renderizado dinámico por menu_controller.js %>
        </nav>

      </aside>

      <%# ============================================================= %>
      <%# CONTENIDO PRINCIPAL %>
      <%# ============================================================= %>
      <div class="flex flex-col flex-1 overflow-hidden">

        <%# TOOLBAR %>
        <header data-testid="toolbar"
                class="flex items-center justify-between bg-white border-b border-gray-200 px-4 h-14 flex-shrink-0 shadow-sm">

          <div class="flex items-center gap-3">
            <%# Toggle sidebar %>
            <button type="button"
                    data-menu-toggle
                    data-testid="menu-toggle"
                    class="p-1.5 rounded-md text-gray-500 hover:text-gray-700 hover:bg-gray-100 transition-colors"
                    aria-label="Menú">
              <span class="material-icons text-xl">menu</span>
            </button>

            <%# Título de página — renderizado en servidor. El toolbar SÍ se reemplaza %>
            <%# en cada visita Turbo (no es permanente), así el título se actualiza solo. %>
            <span data-auth-content class="text-sm font-medium text-gray-700 invisible"><%= content_for?(:page_title) ? yield(:page_title) : '' %></span>
          </div>

          <div class="flex items-center gap-2">
            <span class="text-sm text-gray-500">Compañía:</span>

            <%# Botón selección de empresa %>
            <div class="relative">
              <button data-action="click->company-selector#open contextmenu->company-selector#onContextMenu"
                      data-testid="company-button"
                      class="flex items-center gap-1.5 px-3 py-1.5 bg-blue-600 text-white text-sm rounded-md hover:bg-blue-700 transition-colors max-w-xs truncate"
                      title="">
                <span class="material-icons text-base">business</span>
                <span data-company-selector-target="toolbarLabel" class="truncate">No seleccionada</span>
              </button>

              <%# Context menu — solo visible con F_ModifyCompany %>
              <div data-company-selector-target="contextMenu"
                   class="hidden absolute right-0 top-full mt-1 z-[9999] bg-white border border-gray-200 rounded-lg shadow-lg py-1 min-w-[160px]">
                <button type="button"
                        data-action="click->company-selector#navigateToCompanyEdit"
                        class="w-full flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                  <span class="material-icons text-base text-gray-500">info_outline</span>
                  Ver información
                </button>
              </div>
            </div>
          </div>
        </header>

        <%# Área de contenido %>
        <main data-auth-content class="flex-1 overflow-auto p-6 invisible">
          <%= yield %>
        </main>
      </div>

      <%# ============================================================= %>
      <%# PANEL LATERAL — Company Selector %>
      <%# ============================================================= %>

      <%# Page loader — visible mientras se aplica el cambio de empresa %>
      <%= render 'shared/overlay_loader',
            ctrl:       'company-selector',
            target:     'pageLoader',
            msg_target: nil,
            message:    'Cargando compañía...',
            z_class:    'z-[9999]' %>

      <%# Backdrop %>
      <div data-company-selector-target="panelBackdrop"
           data-action="click->company-selector#overlayClick"
           class="hidden fixed inset-0 z-40 bg-black/40"></div>

      <%# Panel %>
      <div data-company-selector-target="panel"
           data-testid="company-selector-modal"
           class="fixed top-0 right-0 h-full w-full max-w-md bg-white shadow-2xl z-50
                  translate-x-full transition-transform duration-300 ease-in-out flex flex-col">

        <%# Loader de panel completo — visible hasta que cargan las compañías %>
        <div data-company-selector-target="panelLoader"
             class="hidden absolute inset-0 z-[60] flex flex-col items-center justify-center gap-3 bg-white/40 backdrop-blur-[2px]">
          <svg width="44" height="44" viewBox="0 0 50 50" aria-hidden="true">
            <circle cx="25" cy="25" r="20" fill="none" stroke="#e5e7eb" stroke-width="5"></circle>
            <circle cx="25" cy="25" r="20" fill="none" stroke="#2563eb" stroke-width="5"
                    stroke-linecap="round" stroke-dasharray="80 200">
              <animateTransform attributeName="transform" attributeType="XML" type="rotate"
                                from="0 25 25" to="360 25 25" dur="0.8s" repeatCount="indefinite"></animateTransform>
            </circle>
          </svg>
          <p class="text-sm text-gray-500">Cargando compañías...</p>
        </div>

        <%# Header %>
        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100 flex-shrink-0">
          <h3 class="text-base font-semibold text-gray-800">Seleccione una compañía</h3>
          <button data-company-selector-target="cancelBtn"
                  data-action="click->company-selector#close"
                  data-testid="company-cancel-btn"
                  class="hidden p-1 text-gray-400 hover:text-gray-600 rounded hover:bg-gray-100 transition-colors">
            <span class="material-icons text-xl">close</span>
          </button>
        </div>

        <%# Body %>
        <div class="flex-1 min-h-0 px-6 py-5 flex flex-col gap-4">

          <%# Input de búsqueda — fijo (no scrollea con la tabla) %>
          <div class="relative flex-shrink-0">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 material-icons text-gray-400 text-xl">search</span>
            <input type="text"
                   data-company-selector-target="searchInput"
                   data-testid="company-search-input"
                   data-action="input->company-selector#filter"
                   placeholder="Digite el nombre de una compañía"
                   class="w-full pl-10 pr-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
          </div>

          <%# Tabla de compañías (Tabulator, sin paginación) — scroll interno %>
          <div class="flex-1 min-h-0 border border-gray-200 rounded-lg overflow-hidden">
            <div data-company-selector-target="table" class="h-full"></div>
          </div>

        </div>

        <%# Footer %>
        <div class="px-6 py-4 border-t border-gray-100 flex justify-end flex-shrink-0">
          <button data-company-selector-target="confirmBtn"
                  data-action="click->company-selector#confirm"
                  data-testid="company-confirm-btn"
                  disabled
                  class="inline-flex items-center gap-1 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
            <span class="material-icons text-base">check</span>
            Continuar
          </button>
        </div>

      </div>

    </div><%# /controller wrapper %>

  </body>
</html>
